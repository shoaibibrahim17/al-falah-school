---
import "../styles/global.css";
import { SCHOOL } from "../data/school";

const { title } = Astro.props;
const pageTitle = title ? `${title} | ${SCHOOL.shortName}` : `${SCHOOL.name} | ${SCHOOL.tagline}`;
const canonicalUrl = SCHOOL.seo.canonicalUrl;
const ogImageRelative = SCHOOL.seo.ogImage.replace(/^\//, "");
const ogImage = `${canonicalUrl}${ogImageRelative}`;
const phoneNumbers = SCHOOL.contact.phones?.map((phone) => phone.display).filter(Boolean) ?? [];
const whatsappHref = SCHOOL.footer.socialLinks.whatsapp;
const showWhatsappFab = Boolean(whatsappHref && whatsappHref !== "#");

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "School",
  name: SCHOOL.name,
  description: SCHOOL.description,
  url: canonicalUrl,
  address: {
    "@type": "PostalAddress",
    streetAddress: SCHOOL.location.address,
    addressLocality: SCHOOL.location.city,
    addressRegion: SCHOOL.location.state,
    addressCountry: "IN",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: SCHOOL.location.coordinates.lat,
    longitude: SCHOOL.location.coordinates.lng,
  },
  ...(phoneNumbers.length > 0 ? { telephone: phoneNumbers } : {}),
  ...(SCHOOL.contact.email ? { email: SCHOOL.contact.email } : {}),
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={SCHOOL.description} />
    <meta name="theme-color" content="#0F8A3D" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SCHOOL.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={SCHOOL.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={SCHOOL.description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Crimson+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>

    <script is:inline type="application/ld+json" set:html={structuredData}></script>
  </head>
  <body class="bg-white text-charcoal">
    <slot />

    <!-- Floating WhatsApp button -->
    {showWhatsappFab && (
      <a
        href={whatsappHref}
        class="fab-whatsapp"
        aria-label="Chat on WhatsApp"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
      </a>
    )}

    <button
      type="button"
      class="fab-scroll-top"
      aria-label="Scroll to top"
      data-scroll-top
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m18 15-6-6-6 6"/>
      </svg>
    </button>

    <script src="../scripts/reveal.ts"></script>
    <script src="../scripts/motion-enhance.ts"></script>
  </body>
</html>
