---
import { MapPin, Phone, Mail, Clock } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<section id="contact" class="py-12 lg:py-24 bg-ivory">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-8 lg:mb-16">
      <h2 data-animate="fade-up" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4">
        <span class="text-deep-green">Get in</span> Touch
      </h2>
      <p class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.locationSection.subtitle}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 sm:gap-10 lg:gap-16">
      <div class="space-y-6 sm:space-y-8">
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-lg bg-deep-green/10 flex items-center justify-center shrink-0 mt-1">
            <MapPin class="w-5 h-5 text-deep-green" />
          </div>
          <div>
            <h3 class="font-bold text-charcoal font-serif mb-1">{SCHOOL.locationSection.addressLabel}</h3>
            <p class="text-slate">{SCHOOL.location.full}</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-lg bg-deep-green/10 flex items-center justify-center shrink-0 mt-1">
            <Phone class="w-5 h-5 text-deep-green" />
          </div>
          <div>
            <h3 class="font-bold text-charcoal font-serif mb-1">{SCHOOL.locationSection.phoneLabel}</h3>
            <a href={`tel:${SCHOOL.contact.phone}`} class="text-slate hover:text-deep-green transition-colors no-underline focus-visible:outline-gold cursor-pointer">
              {SCHOOL.contact.phone}
            </a>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-lg bg-deep-green/10 flex items-center justify-center shrink-0 mt-1">
            <Mail class="w-5 h-5 text-deep-green" />
          </div>
          <div>
            <h3 class="font-bold text-charcoal font-serif mb-1">{SCHOOL.locationSection.emailLabel}</h3>
            <a href={`mailto:${SCHOOL.contact.email}`} class="text-slate hover:text-deep-green transition-colors no-underline focus-visible:outline-gold cursor-pointer">
              {SCHOOL.contact.email}
            </a>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-lg bg-deep-green/10 flex items-center justify-center shrink-0 mt-1">
            <Clock class="w-5 h-5 text-deep-green" />
          </div>
          <div>
            <h3 class="font-bold text-charcoal font-serif mb-1">{SCHOOL.locationSection.hoursLabel}</h3>
            <p class="text-slate">{SCHOOL.contact.hours}</p>
          </div>
        </div>
      </div>

      <div aria-hidden="true">
        <div class="aspect-[16/9] rounded-xl bg-deep-green/5 border border-ivory-dark flex items-center justify-center p-8">
          <div class="text-center">
            <MapPin class="w-12 h-12 text-deep-green/30 mx-auto mb-3" />
            <p class="text-slate font-medium">{SCHOOL.location.address}</p>
            <p class="text-slate-light text-sm mt-1">Near {SCHOOL.location.landmark}</p>
            <p class="text-xs text-slate-light mt-4">
              {SCHOOL.locationSection.mapPlaceholder}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
