---
import { MapPin, Phone, Mail, ExternalLink } from "lucide-astro";
import { SCHOOL } from "../data/school";

const { lat, lng } = SCHOOL.location.coordinates;
const mapEmbedSrc = `https://www.google.com/maps?q=${lat},${lng}&z=17&output=embed`;
const mapDirectionsHref = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;

type ContactItem = {
  Icon: typeof MapPin;
  label: string;
  value: string;
  href: string | null;
  external?: boolean;
};

const contactItems: ContactItem[] = [
  { Icon: MapPin, label: SCHOOL.locationSection.addressLabel, value: SCHOOL.location.full, href: mapDirectionsHref, external: true },
];
for (const phone of SCHOOL.contact.phones ?? []) {
  contactItems.push({ Icon: Phone, label: SCHOOL.locationSection.phoneLabel, value: phone.display, href: `tel:${phone.href}` });
}
if (SCHOOL.contact.email) {
  contactItems.push({ Icon: Mail, label: SCHOOL.locationSection.emailLabel, value: SCHOOL.contact.email, href: `mailto:${SCHOOL.contact.email}` });
}
---

{SCHOOL.locationSection.enabled && (
<section id="contact" class="relative py-14 sm:py-16 lg:py-20 bg-white overflow-hidden">
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-8 lg:mb-10">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
        {SCHOOL.locationSection.eyebrow}
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        <span class="text-gradient-green">{SCHOOL.locationSection.titleLead}</span> {SCHOOL.locationSection.titleAccent}
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.locationSection.subtitle}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 lg:gap-6 items-stretch">
      <!-- Contact list card -->
      <div data-reveal="slide-left" class="bg-white rounded-2xl border border-ivory-dark p-5 sm:p-6">
        <h3 class="text-sm font-bold text-deep-green uppercase tracking-wider mb-5">{SCHOOL.locationSection.cardHeading}</h3>
        <ul class="space-y-4 sm:space-y-5">
          {contactItems.map((item) => (
            <li class="flex gap-3 items-start">
              <div class="w-8 h-8 rounded-md bg-deep-green/10 flex items-center justify-center shrink-0 mt-0.5">
                <item.Icon class="w-4 h-4 text-deep-green" />
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-[11px] font-semibold text-slate-light uppercase tracking-wider mb-0.5">{item.label}</p>
                {item.href ? (
                  <a
                    href={item.href}
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noopener noreferrer" : undefined}
                    class="inline-flex items-center gap-1.5 text-charcoal font-medium hover:text-deep-green transition-colors duration-200 no-underline focus-visible:outline-deep-green break-words"
                  >
                    <span>{item.value}</span>
                    {item.external && <ExternalLink class="w-3.5 h-3.5 opacity-60" />}
                  </a>
                ) : (
                  <p class="text-charcoal font-medium">{item.value}</p>
                )}
              </div>
            </li>
          ))}
        </ul>

        <div class="mt-6 pt-5 border-t border-ivory-dark">
          <a
            href={mapDirectionsHref}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary no-underline w-full sm:w-auto"
            data-cta
          >
            <MapPin class="w-5 h-5" />
            {SCHOOL.locationSection.directionsLabel}
          </a>
        </div>
      </div>

      <!-- Map frame -->
      <div data-reveal="slide-right" class="relative">
        <div class="relative rounded-2xl overflow-hidden border border-ivory-dark h-full min-h-[260px] sm:min-h-[340px] bg-deep-green/5">
          <iframe
            src={mapEmbedSrc}
            title={`Map showing ${SCHOOL.location.full}`}
            class="absolute inset-0 w-full h-full"
            style="border: 0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
)}
