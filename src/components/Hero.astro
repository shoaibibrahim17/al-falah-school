---
import { ArrowRight, GraduationCap, Library, Shapes, BookOpen } from "lucide-astro";
import { SCHOOL } from "../data/school";

const highlightIcons: Record<string, typeof Library> = {
  Library,
  Playground: Shapes,
  "Focused Learning": BookOpen,
};
---

<section class="relative pt-24 lg:pt-28 pb-12 lg:pb-20 overflow-hidden bg-gradient-to-b from-ivory to-white">
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(#0D5E3E_0.8px,transparent_0.8px)] [background-size:24px_24px] opacity-[0.04]"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-deep-green/5 blur-3xl"></div>
    <div class="absolute -bottom-32 -left-32 w-80 h-80 rounded-full bg-gold/[0.08] blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-hero class="grid lg:grid-cols-12 gap-8 sm:gap-12 lg:gap-16 items-center">
      <!-- Left column -->
      <div data-hero-left class="lg:col-span-7 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-deep-green/10 text-deep-green rounded-full text-sm font-medium mb-4 sm:mb-6">
          <GraduationCap class="w-4 h-4" />
          <span>{SCHOOL.hero.badge}</span>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-6xl xl:text-7xl font-bold font-serif text-charcoal leading-[1.1] mb-4 sm:mb-6 text-balance">
          {SCHOOL.hero.headline}
        </h1>

        <p class="text-base sm:text-lg text-slate leading-relaxed max-w-xl mx-auto lg:mx-0 mb-4 sm:mb-6">
          {SCHOOL.hero.subtitle}
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href={SCHOOL.hero.ctaLink} class="btn-primary no-underline" data-cta>
            {SCHOOL.hero.cta}
            <ArrowRight class="w-5 h-5" />
          </a>
          <a href={SCHOOL.hero.secondaryLink} class="btn-outline no-underline" data-cta>
            {SCHOOL.hero.secondaryCta}
          </a>
        </div>

        <!-- Trust badges as chips -->
        <div data-stagger-group class="flex flex-wrap gap-2 sm:gap-2.5 mt-4 sm:mt-6 justify-center lg:justify-start">
          {SCHOOL.trustBadges.map((badge) => (
            <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-white border border-ivory-dark rounded-full text-sm font-medium text-slate shadow-sm">
              {badge.label}
            </span>
          ))}
        </div>
      </div>

      <!-- Right column: Admission Card -->
      <div data-hero-right data-animate="scale-in" class="lg:col-span-5">
        <div class="admission-card">
          <div class="admission-card-badge">
            {SCHOOL.admissionCard.badge}
          </div>

          <p class="text-xs font-semibold text-gold-dark tracking-[0.15em] uppercase mt-4 sm:mt-6 mb-1 sm:mb-2">
            {SCHOOL.admissionCard.year}
          </p>

          <p class="text-xl sm:text-3xl font-bold font-serif text-charcoal leading-tight">
            {SCHOOL.admissionCard.tagline}
          </p>

          <div class="w-12 h-0.5 bg-gold/40 mt-3 sm:mt-4 mb-4 sm:mb-6"></div>

          <ul class="space-y-3 sm:space-y-4 mb-6 sm:mb-8">
            {SCHOOL.admissionCard.highlights.map((item) => {
              const Icon = highlightIcons[item] || BookOpen;
              return (
                <li class="flex items-center gap-3 text-slate">
                  <div class="w-8 h-8 rounded-lg bg-ivory flex items-center justify-center flex-shrink-0">
                    <Icon class="w-4 h-4 text-deep-green" />
                  </div>
                  <span class="font-medium">{item}</span>
                </li>
              );
            })}
          </ul>

          <a href={SCHOOL.hero.ctaLink} class="admission-card-cta no-underline" data-cta>
            {SCHOOL.hero.admissionCardCta}
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
