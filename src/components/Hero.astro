---
import { ArrowRight, GraduationCap, Library, Shapes, BookOpen, Sparkles } from "lucide-astro";
import { SCHOOL } from "../data/school";

const highlightIcons: Record<string, typeof Library> = {
  Library,
  Playground: Shapes,
  "Focused Learning": BookOpen,
};

const { headline, highlightPhrase } = SCHOOL.hero;
const splitIndex = headline.indexOf(highlightPhrase);
const headlineBefore = splitIndex >= 0 ? headline.slice(0, splitIndex) : headline;
const headlineHighlight = splitIndex >= 0 ? highlightPhrase : "";
const headlineAfter = splitIndex >= 0 ? headline.slice(splitIndex + highlightPhrase.length) : "";
---

<section class="relative pt-8 sm:pt-10 lg:pt-16 pb-12 lg:pb-20 overflow-hidden bg-gradient-to-b from-ivory to-white">
  <!-- Decorative background -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div
      data-parallax="0.15"
      class="absolute inset-0 bg-[radial-gradient(#0D5E3E_0.8px,transparent_0.8px)] [background-size:24px_24px] opacity-[0.04]"
    ></div>
    <div class="breathe-slow absolute -top-24 -right-24 w-96 h-96 rounded-full bg-deep-green/5 blur-3xl"></div>
    <div class="breathe-slow delay absolute -bottom-32 -left-32 w-80 h-80 rounded-full bg-deep-green/[0.06] blur-3xl"></div>

    <!-- Subtle radial vignette to focus center -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_50%,rgba(253,248,240,0.6)_100%)]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-8 sm:gap-12 lg:gap-16 items-center">
      <!-- Left column -->
      <div class="lg:col-span-7 text-center lg:text-left">
        <div class="hero-badge" style="animation-delay: 0s">
          <div class="float-soft inline-flex items-center gap-2 px-4 py-1.5 bg-brand-red/10 text-brand-red rounded-full text-sm font-semibold mb-5 sm:mb-7 ring-1 ring-brand-red/20">
            <span class="relative flex w-1.5 h-1.5">
              <span class="absolute inset-0 rounded-full bg-brand-red/50 ping-soft"></span>
              <span class="relative w-1.5 h-1.5 rounded-full bg-brand-red"></span>
            </span>
            <GraduationCap class="w-4 h-4" />
            <span>{SCHOOL.hero.badge}</span>
          </div>
        </div>

        <h1
          class="hero-reveal text-[2.25rem] sm:text-5xl lg:text-[4.25rem] xl:text-[5rem] font-bold font-serif text-charcoal leading-[1.05] tracking-tight mb-5 sm:mb-7 text-balance"
          style="animation-delay: 0.08s"
        >
          {headlineBefore}<span class="text-gradient-green">{headlineHighlight}</span>{headlineAfter}
        </h1>

        <p class="hero-reveal text-base sm:text-lg lg:text-xl text-slate leading-relaxed max-w-xl mx-auto lg:mx-0 mb-6 sm:mb-8" style="animation-delay: 0.32s">
          {SCHOOL.hero.subtitle}
        </p>

        <!-- CTA buttons -->
        <div class="hero-reveal flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start" style="animation-delay: 0.44s">
          <a href={SCHOOL.hero.ctaLink} class="btn-primary no-underline" data-cta>
            {SCHOOL.hero.cta}
            <ArrowRight class="w-5 h-5" />
          </a>
          <a href={SCHOOL.hero.secondaryLink} class="btn-outline no-underline" data-cta>
            {SCHOOL.hero.secondaryCta}
          </a>
        </div>

        <!-- Trust chips -->
        <div class="hero-reveal flex flex-wrap gap-2 sm:gap-2.5 mt-5 sm:mt-8 justify-center lg:justify-start" style="animation-delay: 0.56s">
          {SCHOOL.trustBadges.map((badge, i) => (
            <span class="hero-badge-chip inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-white/80 backdrop-blur-sm border border-ivory-dark rounded-full text-sm font-medium text-slate shadow-sm" style={`animation-delay: ${0.68 + i * 0.06}s`}>
              {badge.label}
            </span>
          ))}
        </div>
      </div>

      <!-- Right column: Admission Card -->
      <div class="hero-scale lg:col-span-5" style="animation-delay: 0.35s">
        <div class="admission-card" data-tilt="4">
          <!-- Floating sparkle accent -->
          <div class="absolute -top-3 -right-3 w-10 h-10 rounded-full bg-gradient-to-br from-deep-green to-deep-green-light flex items-center justify-center shadow-lg shadow-deep-green/30 float-soft" aria-hidden="true">
            <Sparkles class="w-5 h-5 text-white" />
          </div>

          <div class="admission-card-badge">
            {SCHOOL.admissionCard.badge}
          </div>

          <p class="text-xs font-semibold text-deep-green tracking-[0.18em] uppercase mt-5 sm:mt-7 mb-1.5 sm:mb-2.5">
            {SCHOOL.admissionCard.year}
          </p>

          <p class="text-2xl sm:text-[2rem] font-bold font-serif text-charcoal leading-[1.15]">
            {SCHOOL.admissionCard.tagline}
          </p>

          <div class="flex items-center gap-2 mt-4 sm:mt-5 mb-5 sm:mb-7">
            <div class="h-px flex-1 bg-gradient-to-r from-deep-green/50 to-transparent"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-deep-green/60"></div>
            <div class="h-px flex-1 bg-gradient-to-l from-deep-green/50 to-transparent"></div>
          </div>

          <ul class="space-y-3 sm:space-y-3.5 mb-6 sm:mb-8">
            {SCHOOL.admissionCard.highlights.map((item) => {
              const Icon = highlightIcons[item] || BookOpen;
              return (
                <li class="flex items-center gap-3 text-slate">
                  <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-deep-green/10 to-deep-green/[0.03] flex items-center justify-center flex-shrink-0 ring-1 ring-deep-green/15">
                    <Icon class="w-4 h-4 text-deep-green" />
                  </div>
                  <span class="font-medium">{item}</span>
                </li>
              );
            })}
          </ul>

          <a href={SCHOOL.hero.ctaLink} class="admission-card-cta no-underline w-full" data-cta>
            {SCHOOL.hero.admissionCardCta}
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
