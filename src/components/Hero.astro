---
import { ArrowRight, MapPin } from "lucide-astro";
import { SCHOOL } from "../data/school";
import { assetUrl } from "../utils/assetUrl";

const { hero } = SCHOOL;
const hasBgImage = hero.backgroundImage?.isActive && hero.backgroundImage?.src;
const hasVisualImage = hero.visualImage?.isActive && hero.visualImage?.src;
const admissionCardEnabled = hero.admissionCard?.enabled !== false; // default true
const admissionCardStyle = hero.admissionCard?.style ?? "pulse";
---

<section class="relative pt-2 sm:pt-8 lg:pt-14 pb-7 sm:pb-10 lg:pb-[4.5rem] overflow-hidden">

  {/* ── Premium blurred hero background ── */}
  {hasBgImage && (
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      {/* Background photo — scaled 1.05x to hide blur edges, visible but atmospheric */}
      <img
        src={assetUrl(hero.backgroundImage.src)}
        alt=""
        class="hero-bg-img"
        loading="eager"
      />
      {/* Left-to-right readability gradient: ivory-left (readable text), transparent-right (photo visible) */}
      <div class="hero-bg-overlay"></div>
      {/* Subtle green tint for premium feel */}
      <div class="hero-bg-green-tint"></div>
    </div>
  )}

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-4 sm:gap-6 lg:gap-14 items-start lg:items-center">

      {/* ── Left: text content ── */}
      <div class="lg:col-span-7 text-left max-w-[34rem] mx-auto lg:mx-0">
        {/* Admissions badge — subtle pulsing attention-grabber */}
        <div class="hero-badge" style="animation-delay: 0s">
          <div class="hero-admission-flash inline-flex items-center gap-2 px-3.5 py-1.5 bg-brand-red/10 text-brand-red rounded-full text-[0.8125rem] sm:text-sm font-semibold mb-4 sm:mb-6 ring-1 ring-brand-red/20">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-red"></span>
            <span>{hero.badge}</span>
          </div>
        </div>

        {/* H1 — school name only, clean */}
        <h1
          class="hero-reveal text-[2.35rem] sm:text-[2.85rem] lg:text-[4.15rem] xl:text-[4.8rem] font-bold font-serif text-charcoal leading-[1.02] tracking-tight max-w-[11.75rem] sm:max-w-none mb-3 sm:mb-4"
          style="animation-delay: 0.08s"
        >
          {hero.headline}
        </h1>

        {/* Location — secondary, clearly below H1 */}
        <div class="hero-reveal flex items-center justify-start gap-2 text-slate text-sm sm:text-base mb-4 sm:mb-5" style="animation-delay: 0.16s">
          <MapPin class="w-4 h-4 text-deep-green shrink-0" />
          <span class="max-w-[28ch] sm:max-w-none">{SCHOOL.location.full}</span>
        </div>

        {/* Subtitle */}
        <p class="hero-reveal text-[0.95rem] sm:text-lg lg:text-xl text-slate leading-relaxed max-w-[24rem] sm:max-w-xl mx-0 mb-5 sm:mb-7" style="animation-delay: 0.24s">
          {hero.subtitle}
        </p>

        {/* Primary CTA only */}
        <div class="hero-reveal flex flex-wrap gap-2.5 sm:gap-3 justify-start" style="animation-delay: 0.32s">
          <a href={hero.ctaLink} class="btn-primary no-underline hero-cta-btn" data-cta>
            {hero.cta}
            <ArrowRight class="w-4 h-4 sm:w-5 sm:h-5" />
          </a>
          <a href={hero.secondaryLink} class="btn-outline no-underline hero-cta-btn" data-cta>
            {hero.secondaryCta}
          </a>
        </div>
      </div>

      {/* ── Right: school building visual card ── */}
      {hasVisualImage ? (
        <div class="hero-scale lg:col-span-5 relative max-w-[24rem] sm:max-w-[28rem] lg:max-w-none mx-auto w-full pb-0 lg:pb-10" style="animation-delay: 0.35s">
          {/* Clean card with green border accent */}
          <div class="relative rounded-2xl overflow-hidden border border-deep-green/20 shadow-md shadow-deep-green/8 bg-white">
            {/* Green top accent bar */}
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-deep-green-light via-deep-green to-deep-green-dark z-10"></div>

            <img
              src={assetUrl(hero.visualImage.src)}
              alt={hero.visualImage.alt}
              class="w-full aspect-[4/2.55] sm:aspect-[4/3] object-cover"
              loading="eager"
            />

            {/* Caption at bottom */}
            {hero.visualImage.caption && (
              <div class="absolute bottom-0 inset-x-0 px-4 py-3 bg-gradient-to-t from-charcoal/60 to-transparent">
                <p class="text-white/90 text-sm font-medium">{hero.visualImage.caption}</p>
              </div>
            )}
          </div>

        </div>
      ) : (
        /* Fallback: admission card if no visual image */
        <div class="hero-scale lg:col-span-5 max-w-[24rem] sm:max-w-[28rem] lg:max-w-none mx-auto w-full" style="animation-delay: 0.35s">
          <div class={`admission-card ${cardAnimClass} hero-admission-card`} data-admission-anim={admissionCardEnabled ? admissionCardStyle : "off"}>
            <div class="admission-card-badge">{hero.admissionCard.badge}</div>
            <p class="text-[11px] sm:text-xs font-semibold text-deep-green tracking-[0.16em] uppercase mt-3 sm:mt-4 mb-1.5 sm:mb-2">{hero.admissionCard.eyebrow}</p>
            <p class="text-[1.35rem] sm:text-[1.8rem] font-bold font-serif text-charcoal leading-[1.12]">{hero.admissionCard.headline}</p>
            <div class="flex items-center gap-2 mt-3 sm:mt-4 mb-4 sm:mb-5">
              <div class="h-px flex-1 bg-gradient-to-r from-deep-green/50 to-transparent"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-deep-green/60"></div>
              <div class="h-px flex-1 bg-gradient-to-l from-deep-green/50 to-transparent"></div>
            </div>
            <a href={hero.admissionCard.ctaHref} class="admission-card-cta no-underline w-full text-sm" data-cta>
              {hero.admissionCard.ctaLabel}
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </div>
      )}

    </div>
  </div>
</section>

<style>
  /* Hero background image — scaled 1.05x to hide blur edges */
  .hero-bg-img {
    position: absolute;
    inset: -5%;
    width: 110%;
    height: 110%;
    object-fit: cover;
    object-position: center;
    filter: blur(3px) saturate(1.00);
    opacity: 0.88;
  }

  /* Left-to-right readability gradient:
     Left (text area)  = 60% ivory — photo clearly visible behind text
     Center            = 32% ivory — photo prominent
     Right             = 10% ivory — photo shows through strongly */
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(253, 248, 240, 0.60) 0%,
      rgba(253, 248, 240, 0.32) 40%,
      rgba(253, 248, 240, 0.10) 100%
    );
  }

  /* Subtle green tint — adds premium depth */
  .hero-bg-green-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(15, 100, 55, 0.08) 0%,
      transparent 55%
    );
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-bg-img {
      animation: hero-bg-scale 20s ease-out forwards;
    }
    @keyframes hero-bg-scale {
      from { transform: scale(1.08); }
      to   { transform: scale(1.05); }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg-img {
      transform: scale(1.05);
    }
  }

  /* Mobile: tighter hero stack so the visual card and admission card feel connected */
  @media (max-width: 639px) {
    .hero-bg-img {
      opacity: 0.7;
      filter: blur(4px) saturate(0.94);
    }
    .hero-bg-overlay {
      background: linear-gradient(
        to right,
        rgba(253, 248, 240, 0.74) 0%,
        rgba(253, 248, 240, 0.52) 42%,
        rgba(253, 248, 240, 0.18) 100%
      );
    }
    .hero-cta-btn {
      min-height: 2.75rem;
      padding-inline: 1rem;
      padding-block: 0.75rem;
      font-size: 0.95rem;
    }
    .hero-admission-card {
      width: 100%;
      margin-left: auto;
      margin-right: auto;
      padding: 1rem;
      border-radius: 1rem;
    }
  }

  /* ── Hero Admission Flash Animation ─────────────────────── */
  /* Subtle pulsing glow — one animation, less visual noise */
  .hero-admission-flash {
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-brand-red) 30%, transparent);
    transition: box-shadow 400ms var(--ease-ios-out);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-admission-flash {
      animation: hero-flash-pulse 2.4s var(--ease-ios-out) infinite;
    }
  }

  @keyframes hero-flash-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-brand-red) 30%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-brand-red) 0%, transparent);
    }
  }
</style>
