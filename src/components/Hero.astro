---
import { ArrowRight, GraduationCap, MapPin } from "lucide-astro";
import { SCHOOL } from "../data/school";
import { assetUrl } from "../utils/assetUrl";

const { hero } = SCHOOL;
const hasBgImage = hero.backgroundImage?.isActive && hero.backgroundImage?.src;
const hasVisualImage = hero.visualImage?.isActive && hero.visualImage?.src;
---

<section class="relative pt-8 sm:pt-10 lg:pt-16 pb-12 lg:pb-20 overflow-hidden">

  {/* ── Premium blurred hero background ── */}
  {hasBgImage && (
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      {/* Background photo — scaled 1.05x to hide blur edges, visible but atmospheric */}
      <img
        src={assetUrl(hero.backgroundImage.src)}
        alt=""
        class="hero-bg-img"
        loading="eager"
      />
      {/* Left-to-right readability gradient: ivory-left (readable text), transparent-right (photo visible) */}
      <div class="hero-bg-overlay"></div>
      {/* Subtle green tint for premium feel */}
      <div class="hero-bg-green-tint"></div>
    </div>
  )}

  {/* Decorative blobs only when no background image */}
  {!hasBgImage && (
    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
      <div class="breathe-slow absolute -top-24 -right-24 w-96 h-96 rounded-full bg-deep-green/5 blur-3xl"></div>
      <div class="breathe-slow delay absolute -bottom-32 -left-32 w-80 h-80 rounded-full bg-deep-green/[0.06] blur-3xl"></div>
    </div>
  )}

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-8 sm:gap-12 lg:gap-16 items-center">

      {/* ── Left: text content ── */}
      <div class="lg:col-span-7 text-center lg:text-left">
        {/* Admissions badge — subtle pulsing attention-grabber */}
        <div class="hero-badge" style="animation-delay: 0s">
          <div class="hero-admission-flash inline-flex items-center gap-2 px-4 py-1.5 bg-brand-red/10 text-brand-red rounded-full text-sm font-semibold mb-5 sm:mb-7 ring-1 ring-brand-red/20">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-red"></span>
            <span>{hero.badge}</span>
          </div>
        </div>

        {/* H1 — school name only, clean */}
        <h1
          class="hero-reveal text-[2.25rem] sm:text-5xl lg:text-[4.25rem] xl:text-[5rem] font-bold font-serif text-charcoal leading-[1.05] tracking-tight mb-3 sm:mb-4"
          style="animation-delay: 0.08s"
        >
          {hero.headline}
        </h1>

        {/* Location — secondary, clearly below H1 */}
        <div class="hero-reveal flex items-center justify-center lg:justify-start gap-2 text-slate text-sm sm:text-base mb-5 sm:mb-6" style="animation-delay: 0.16s">
          <MapPin class="w-4 h-4 text-deep-green shrink-0" />
          <span>{SCHOOL.location.full}</span>
        </div>

        {/* Subtitle */}
        <p class="hero-reveal text-base sm:text-lg lg:text-xl text-slate leading-relaxed max-w-xl mx-auto lg:mx-0 mb-6 sm:mb-8" style="animation-delay: 0.24s">
          {hero.subtitle}
        </p>

        {/* Primary CTA only */}
        <div class="hero-reveal flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start" style="animation-delay: 0.32s">
          <a href={hero.ctaLink} class="btn-primary no-underline" data-cta>
            {hero.cta}
            <ArrowRight class="w-5 h-5" />
          </a>
          <a href={hero.secondaryLink} class="btn-outline no-underline" data-cta>
            {hero.secondaryCta}
          </a>
        </div>
      </div>

      {/* ── Right: school building visual card ── */}
      {hasVisualImage ? (
        <div class="hero-scale lg:col-span-5" style="animation-delay: 0.35s">
          {/* Clean card with green border accent */}
          <div class="relative rounded-xl overflow-hidden border border-deep-green/20 shadow-lg shadow-deep-green/10">
            {/* Green top accent bar */}
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-deep-green-light via-deep-green to-deep-green-dark z-10"></div>

            <img
              src={assetUrl(hero.visualImage.src)}
              alt={hero.visualImage.alt}
              class="w-full aspect-[4/3] object-cover"
              loading="eager"
            />

            {/* Caption at bottom */}
            {hero.visualImage.caption && (
              <div class="absolute bottom-0 inset-x-0 px-4 py-3 bg-gradient-to-t from-charcoal/60 to-transparent">
                <p class="text-white/90 text-sm font-medium">{hero.visualImage.caption}</p>
              </div>
            )}
          </div>
        </div>
      ) : (
        /* Fallback: admission card if no visual image */
        <div class="hero-scale lg:col-span-5" style="animation-delay: 0.35s">
          <div class="admission-card" data-tilt="4">
            <div class="admission-card-badge">Admissions Enquiry Open</div>
            <p class="text-xs font-semibold text-deep-green tracking-[0.18em] uppercase mt-5 sm:mt-7 mb-1.5 sm:mb-2.5">Academic Year 2026–27</p>
            <p class="text-2xl sm:text-[2rem] font-bold font-serif text-charcoal leading-[1.15]"> basics · habits · growth</p>
            <div class="flex items-center gap-2 mt-4 sm:mt-5 mb-5 sm:mb-7">
              <div class="h-px flex-1 bg-gradient-to-r from-deep-green/50 to-transparent"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-deep-green/60"></div>
              <div class="h-px flex-1 bg-gradient-to-l from-deep-green/50 to-transparent"></div>
            </div>
            <a href={hero.ctaLink} class="admission-card-cta no-underline w-full" data-cta>
              Enquire Now
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
        </div>
      )}

    </div>
  </div>
</section>

<style>
  /* Hero background image — scaled 1.05x to hide blur edges */
  .hero-bg-img {
    position: absolute;
    inset: -5%;
    width: 110%;
    height: 110%;
    object-fit: cover;
    object-position: center;
    filter: blur(3px) saturate(1.00);
    opacity: 0.88;
  }

  /* Left-to-right readability gradient:
     Left (text area)  = 60% ivory — photo clearly visible behind text
     Center            = 32% ivory — photo prominent
     Right             = 10% ivory — photo shows through strongly */
  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(253, 248, 240, 0.60) 0%,
      rgba(253, 248, 240, 0.32) 40%,
      rgba(253, 248, 240, 0.10) 100%
    );
  }

  /* Subtle green tint — adds premium depth */
  .hero-bg-green-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(15, 100, 55, 0.08) 0%,
      transparent 55%
    );
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-bg-img {
      animation: hero-bg-scale 20s ease-out forwards;
    }
    @keyframes hero-bg-scale {
      from { transform: scale(1.08); }
      to   { transform: scale(1.05); }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg-img {
      transform: scale(1.05);
    }
  }

  /* Mobile: moderate overlay for readability */
  @media (max-width: 639px) {
    .hero-bg-img {
      opacity: 0.72;
      filter: blur(5px) saturate(0.95);
    }
    .hero-bg-overlay {
      background: linear-gradient(
        to right,
        rgba(253, 248, 240, 0.72) 0%,
        rgba(253, 248, 240, 0.48) 40%,
        rgba(253, 248, 240, 0.18) 100%
      );
    }
  }

  /* ── Hero Admission Flash Animation ─────────────────────── */
  /* Subtle pulsing glow — one animation, less visual noise */
  .hero-admission-flash {
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-brand-red) 30%, transparent);
    transition: box-shadow 400ms var(--ease-ios-out);
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-admission-flash {
      animation: hero-flash-pulse 2.4s var(--ease-ios-out) infinite;
    }
  }

  @keyframes hero-flash-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-brand-red) 30%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-brand-red) 0%, transparent);
    }
  }
</style>