---
import { ArrowRight } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

{SCHOOL.admissionsCta.enabled && (
<section class="relative py-10 sm:py-12 lg:py-14 bg-deep-green overflow-hidden">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent" aria-hidden="true"></div>
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-reveal class="rounded-2xl border border-white/10 bg-white/[0.04] px-4 py-5 sm:px-5 sm:py-6 lg:px-6 backdrop-blur-sm">
      <div class="grid grid-cols-[minmax(0,1.5fr)_auto] gap-4 lg:gap-6 items-center">
        <div class="text-center lg:text-left">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/12 text-white rounded-full text-[11px] font-semibold uppercase tracking-wider mb-3 border border-white/15">
            {SCHOOL.admissionsCta.pillLabel}
          </div>
          <h2 class="text-2xl sm:text-3xl lg:text-[2.25rem] font-bold text-white mb-2.5 leading-[1.1] tracking-tight">
            {SCHOOL.admissionsCta.heading}
          </h2>
          <p class="text-white/82 text-base sm:text-[1.02rem] leading-relaxed max-w-2xl mx-auto lg:mx-0">
            {SCHOOL.admissionsCta.subtitle}
          </p>
        </div>
        <div class="flex flex-row flex-nowrap gap-2 min-w-[12rem]">
          <a href={SCHOOL.admissionsCta.primaryCtaLink} class="btn-secondary no-underline justify-center flex-1 min-w-0" data-cta="pulse">
            {SCHOOL.admissionsCta.primaryCta}
            <ArrowRight class="w-5 h-5" />
          </a>
          <a href={SCHOOL.admissionsCta.secondaryCtaLink} class="inline-flex items-center justify-center gap-2 px-4 py-3 rounded-xl border border-white/18 text-sm font-semibold text-white/85 hover:text-white transition-colors duration-200 no-underline focus-visible:outline-white flex-1 min-w-0">
            {SCHOOL.admissionsCta.secondaryCta}
            <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
)}
