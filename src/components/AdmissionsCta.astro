---
import { ArrowRight, Phone, Sparkles } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<section class="relative py-16 lg:py-28 bg-gradient-to-br from-deep-green via-deep-green to-deep-green-dark overflow-hidden">
  <!-- Decorative pattern + sheen -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.08)_1px,transparent_1px)] [background-size:24px_24px] opacity-60"></div>
    <div class="cta-sheen"></div>
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-gold/15 blur-3xl breathe-slow"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-gold/10 blur-3xl breathe-slow delay"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div data-reveal>
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-gold/20 text-gold-light rounded-full text-xs font-semibold uppercase tracking-wider mb-5 backdrop-blur-sm border border-gold/20">
        <Sparkles class="w-3.5 h-3.5" />
        {SCHOOL.admissionCard.year}
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-[3.5rem] font-bold text-white mb-5 leading-[1.1] tracking-tight">
        {SCHOOL.admissionsCta.heading}
      </h2>
      <p class="text-white/85 text-base sm:text-lg lg:text-xl leading-relaxed max-w-2xl mx-auto mb-8 sm:mb-10">
        {SCHOOL.admissionsCta.subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
        <a
          href={SCHOOL.admissionsCta.ctaLink}
          class="btn-secondary no-underline shadow-xl shadow-gold/30"
          data-cta="pulse"
          data-magnetic="0.25"
          data-magnetic-radius="100"
        >
          {SCHOOL.admissionsCta.cta}
          <ArrowRight class="w-5 h-5" />
        </a>
        <a
          href={`tel:${SCHOOL.contact.phone}`}
          class="inline-flex items-center justify-center gap-2 px-5 sm:px-8 py-4 border-2 border-white/30 hover:border-white/60 text-white text-sm sm:text-base font-semibold rounded-xl transition-colors duration-200 no-underline focus-visible:outline-gold cursor-pointer backdrop-blur-sm"
          data-cta
        >
          <Phone class="w-5 h-5" />
          {SCHOOL.contact.phone}
        </a>
      </div>
    </div>
  </div>
</section>
