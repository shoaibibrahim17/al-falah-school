---
import { ArrowRight, Phone } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<section class="py-12 lg:py-24 bg-gradient-to-r from-deep-green to-deep-green-dark">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div data-animate="fade-up">
      <h2 class="text-2xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
        {SCHOOL.admissionsCta.heading}
      </h2>
      <p class="text-white/80 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto mb-6 sm:mb-8">
        {SCHOOL.admissionsCta.subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={SCHOOL.admissionsCta.ctaLink}
          class="btn-secondary no-underline shadow-lg shadow-gold/20"
          data-cta="pulse"
        >
          {SCHOOL.admissionsCta.cta}
          <ArrowRight class="w-5 h-5" />
        </a>
        <a
          href={`tel:${SCHOOL.contact.phone}`}
          class="inline-flex items-center justify-center gap-2 px-5 sm:px-8 py-4 border-2 border-white/30 hover:border-white/60 text-white text-sm sm:text-base font-semibold rounded-xl transition-colors duration-200 no-underline focus-visible:outline-gold cursor-pointer"
          data-cta
        >
          <Phone class="w-5 h-5" />
          {SCHOOL.contact.phone}
        </a>
      </div>
    </div>
  </div>
</section>
