---
/**
 * AcademicBackgroundDoodles.astro
 * Site-wide decorative line-art doodle layer.
 *
 * Renders a fixed, pointer-events-none SVG layer behind all page content.
 * Uses only Al-Falah brand colors at low opacity.
 *
 * Usage:
 *   import AcademicBackgroundDoodles from "./AcademicBackgroundDoodles.astro";
 *   <AcademicBackgroundDoodles />
 *
 * CMS: NOT managed — code-only decorative asset.
 * All positioning is in CSS, not in data files.
 *
 * Subject coverage:
 *   Science (atom, beaker), Mathematics (triangle, ruler, pi, compass),
 *   Geography/Social (globe, compass, map), English (book, pencil),
 *   Computer (code brackets), General Learning (graduation cap, star, paper plane)
 */

// Reduced by ~20% per visual QA — stroke at 0.18 is subtle but visible enough on white
// Effective opacity = stroke * CSS container opacity (e.g. 0.18 * 0.40 ≈ 0.072)
const STROKE = "rgba(15, 100, 55, 0.18)";
const STROKE_LIGHT = "rgba(15, 100, 55, 0.09)";
const FILL_LIGHT = "rgba(15, 100, 55, 0.05)";
---

<div
  class="site-doodles"
  aria-hidden="true"
  role="presentation"
>
  <!-- ═══════════════════════════════════════════
       SCIENCE — Atom
       Position: upper-left, visible during hero
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-atom">
    <svg width="34" height="34" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="3" fill={FILL_LIGHT} stroke={STROKE} stroke-width="1.2"/>
      <ellipse cx="20" cy="20" rx="16" ry="7" stroke={STROKE} stroke-width="1.1" transform="rotate(0 20 20)"/>
      <ellipse cx="20" cy="20" rx="16" ry="7" stroke={STROKE} stroke-width="1.1" transform="rotate(60 20 20)"/>
      <ellipse cx="20" cy="20" rx="16" ry="7" stroke={STROKE} stroke-width="1.1" transform="rotate(120 20 20)"/>
      <circle cx="36" cy="20" r="1.5" fill={FILL_LIGHT} stroke={STROKE} stroke-width="0.9"/>
      <circle cx="30" cy="33" r="1.5" fill={FILL_LIGHT} stroke={STROKE} stroke-width="0.9"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       SCIENCE — Beaker / Flask
       Position: top-right area
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-beaker">
    <svg width="26" height="26" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 4H18V10L23 22C23.5 23.5 22.5 25 21 25H7C5.5 25 4.5 23.5 5 22L10 10V4Z" stroke={STROKE} stroke-width="1.2" stroke-linejoin="round"/>
      <path d="M10 4H18" stroke={STROKE} stroke-width="1.2" stroke-linecap="round"/>
      <path d="M7.5 20C7.5 20 9 18 14 18C19 18 20.5 20 20.5 20" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <circle cx="9" cy="17" r="1" fill={FILL_LIGHT} stroke={STROKE} stroke-width="0.8"/>
      <circle cx="12" cy="15" r="1" fill={FILL_LIGHT} stroke={STROKE} stroke-width="0.8"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       MATHEMATICS — Triangle with ruler markings
       Position: mid-left, aligned with about section
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-triangle">
    <svg width="30" height="30" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M6 36L22 8L38 36H6Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M10 32L14 29M16 26.5L20 23.5M22 21L26 18M28 15.5L32 12.5" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <path d="M10 30H18M9 33H15" stroke={STROKE_LIGHT} stroke-width="0.8" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       GEOGRAPHY / SOCIAL — Globe with meridians
       Position: right side, upper-third
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-globe">
    <svg width="38" height="38" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="22" cy="22" r="17" stroke={STROKE} stroke-width="1.4"/>
      <ellipse cx="22" cy="22" rx="17" ry="7" stroke={STROKE_LIGHT} stroke-width="1"/>
      <ellipse cx="22" cy="22" rx="7" ry="17" stroke={STROKE_LIGHT} stroke-width="1"/>
      <path d="M5 22H39" stroke={STROKE_LIGHT} stroke-width="0.8"/>
      <path d="M22 13C19.5 13 17.5 14.8 17.5 16.9C17.5 20 22 25 22 25C22 25 26.5 20 26.5 16.9C26.5 14.8 24.5 13 22 13Z" stroke={STROKE} stroke-width="1.1" stroke-linejoin="round"/>
      <circle cx="22" cy="16.9" r="1.8" stroke={STROKE} stroke-width="1"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       MATHEMATICS — Ruler with markings
       Position: center-left, around academics area
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-ruler">
    <svg width="26" height="26" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="9" width="24" height="10" rx="2" stroke={STROKE} stroke-width="1.2"/>
      <path d="M6 9V12M10 9V11M14 9V12M18 9V11M22 9V12" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
      <path d="M6 19V21.5M10 19V20.5M14 19V21.5M18 19V20.5M22 19V21.5" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       ENGLISH / LANGUAGES — Open Book
       Position: right-center, mid page
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-book">
    <svg width="44" height="44" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M26 44V10" stroke={STROKE} stroke-width="1.4" stroke-linecap="round"/>
      <path d="M26 10C20 10 14 12 10 14C6 16 4 19 4 23C4 28 8 32 13 34C18 36 26 38 26 38" stroke={STROKE} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M26 10C32 10 38 12 42 14C46 16 48 19 48 23C48 28 44 32 39 34C34 36 26 38 26 38" stroke={STROKE} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 20H18M9 25H17M10 30H16" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <path d="M42 20H34M43 25H35M42 30H36" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       COMPUTER — Code brackets  </>  with slash
       Position: left area, facilities section
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-code">
    <svg width="26" height="26" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M18 6L10 14L18 22" stroke={STROKE} stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 6L18 14L10 22" stroke={STROKE} stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M15.5 5L12.5 23" stroke={STROKE_LIGHT} stroke-width="1.1" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       GEOGRAPHY / SOCIAL — Compass rose
       Position: right side, lower-middle
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-compass">
    <svg width="30" height="30" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="16" cy="16" r="13" stroke={STROKE} stroke-width="1.2"/>
      <circle cx="16" cy="16" r="3" stroke={STROKE} stroke-width="1"/>
      <!-- Compass directions -->
      <path d="M16 3L17.8 13.2H14.2L16 3Z" fill={STROKE}/>
      <path d="M16 29L14.2 18.8H17.8L16 29Z" stroke={STROKE} stroke-width="1" stroke-linejoin="round"/>
      <!-- Cardinal tick marks -->
      <path d="M16 3V5M16 27V29M3 16H5M27 16H29" stroke={STROKE_LIGHT} stroke-width="1.2" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       GENERAL LEARNING — Graduation Cap
       Position: far left, facilities area
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-cap">
    <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M20 5L5 13L20 21L35 13L20 5Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M8 15H32V22C32 26.4 29.2 30 26 31.5C24.5 32.3 23 32.8 21 32.8C19 32.8 17.5 32.3 16 31.5C12.8 30 10 26.4 10 22V15Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M20 21V30" stroke={STROKE} stroke-width="1.1" stroke-linecap="round"/>
      <circle cx="20" cy="32" r="1.8" fill={FILL_LIGHT} stroke={STROKE} stroke-width="0.9"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       MATHEMATICS — Pi symbol
       Position: center-right, academic levels area
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-pi">
    <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
      <text x="0" y="20" font-size="20" fill={STROKE} font-family="serif" font-style="italic" aria-hidden="true">π</text>
      <!-- Underline for the pi -->
      <path d="M3 23H23" stroke={STROKE} stroke-width="1.2" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       ENGLISH — Pencil
       Position: right side, around gallery section
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-pencil">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Pencil body -->
      <path d="M8 22L4 26L2 24L6 20L8 22Z" stroke={STROKE} stroke-width="1.1" stroke-linejoin="round"/>
      <path d="M8 22L20 10L24 14L12 26L8 22Z" stroke={STROKE} stroke-width="1.2" stroke-linejoin="round"/>
      <path d="M20 10L22 8L24 10L22 12" stroke={STROKE} stroke-width="1.1" stroke-linejoin="round"/>
      <!-- Eraser metal band -->
      <path d="M22 8L24 6" stroke={STROKE} stroke-width="1.2" stroke-linecap="round"/>
      <!-- Pencil tip -->
      <path d="M4 26L2 24L6 20" stroke={STROKE} stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
      <!-- Lines on pencil body -->
      <path d="M10 18L14 14" stroke={STROKE_LIGHT} stroke-width="0.8" stroke-linecap="round"/>
      <path d="M12 20L16 16" stroke={STROKE_LIGHT} stroke-width="0.8" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       GENERAL LEARNING — Achievement Star
       Position: left side, near contact section
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-star">
    <svg width="26" height="26" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M14 3L16.9 10.6L25 11.3L18.7 16.5L20.5 24.3L14 20L7.5 24.3L9.3 16.5L3 11.3L11.1 10.6L14 3Z"
        stroke={STROKE} stroke-width="1.2" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       SOCIAL / GEOGRAPHY — Map outline
       Position: center, around gallery
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-map">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 8L9 4L15 6L21 3L25 7L24 14L26 20L22 25L16 24L10 26L6 22L4 16L3 10L4 8Z" stroke={STROKE} stroke-width="1.2" stroke-linejoin="round"/>
      <path d="M9 4L9 14L15 18" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
      <path d="M15 6L15 18" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
      <circle cx="9" cy="4" r="1.2" fill={FILL_LIGHT} stroke={STROKE} stroke-width="0.8"/>
      <circle cx="25" cy="7" r="1.2" fill={FILL_LIGHT} stroke={STROKE} stroke-width="0.8"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       COMPUTER / DIGITAL — Monitor
       Position: right side, lower page
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-monitor">
    <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Monitor frame -->
      <rect x="2" y="4" width="26" height="18" rx="2" stroke={STROKE} stroke-width="1.2"/>
      <!-- Screen area -->
      <rect x="4" y="6" width="22" height="14" rx="1" stroke={STROKE_LIGHT} stroke-width="0.9"/>
      <!-- Code lines on screen -->
      <path d="M6 9H14M6 12H18M6 15H12" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <!-- Monitor stand -->
      <path d="M11 22V26M19 22V26" stroke={STROKE} stroke-width="1.1" stroke-linecap="round"/>
      <path d="M8 26H22" stroke={STROKE} stroke-width="1.2" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       GENERAL LEARNING — Paper Plane
       Position: center-left, lower section
  ════════════════════════════════════════════════ -->
  <div class="doodle doodle-paper-plane">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Paper plane body -->
      <path d="M3 14L25 3L13 25L11 15L3 14Z" stroke={STROKE} stroke-width="1.2" stroke-linejoin="round"/>
      <!-- Center fold line -->
      <path d="M3 14L13 25" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
      <!-- Wing top crease -->
      <path d="M3 14L25 3L11 15" stroke={STROKE_LIGHT} stroke-width="0.8" stroke-linejoin="round"/>
    </svg>
  </div>

</div>

<style>
  /* ── Site-wide doodle layer ─────────────────────── */
  .site-doodles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    user-select: none;
    -webkit-user-select: none;
    z-index: 0;
    overflow: hidden;
  }

  .doodle {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Desktop positions (10-16 doodles) ─────────── */
  /* Effective opacity = stroke_color(0.18) * container_opacity ≈ 0.055–0.09 — subtle */
  /* D1: Atom — upper left, hero area */
  .doodle-atom {
    top: 9%;
    left: 3%;
    opacity: 0.40;
    transform: rotate(-5deg);
  }

  /* D2: Beaker — upper right */
  .doodle-beaker {
    top: 5%;
    right: 4%;
    opacity: 0.32;
    transform: rotate(8deg);
  }

  /* D3: Triangle — mid-left */
  .doodle-triangle {
    top: 38%;
    left: 1.5%;
    opacity: 0.32;
    transform: rotate(-12deg);
  }

  /* D4: Globe — right side, upper-middle */
  .doodle-globe {
    top: 22%;
    right: 2%;
    opacity: 0.32;
    transform: rotate(4deg);
  }

  /* D5: Ruler — center-left */
  .doodle-ruler {
    top: 48%;
    left: 4%;
    opacity: 0.28;
    transform: rotate(6deg);
  }

  /* D6: Book — right-center */
  .doodle-book {
    top: 42%;
    right: 3%;
    opacity: 0.30;
    transform: rotate(-6deg);
  }

  /* D7: Code brackets — left side */
  .doodle-code {
    top: 58%;
    left: 2%;
    opacity: 0.30;
    transform: rotate(10deg);
  }

  /* D8: Compass — right side, lower-middle */
  .doodle-compass {
    top: 62%;
    right: 5%;
    opacity: 0.28;
    transform: rotate(-8deg);
  }

  /* D9: Graduation Cap — far left */
  .doodle-cap {
    top: 72%;
    left: 1%;
    opacity: 0.28;
    transform: rotate(5deg);
  }

  /* D10: Pi — center-right */
  .doodle-pi {
    top: 78%;
    right: 35%;
    opacity: 0.30;
  }

  /* D11: Pencil — right side */
  .doodle-pencil {
    top: 82%;
    right: 2%;
    opacity: 0.27;
    transform: rotate(-15deg);
  }

  /* D12: Star — left side, lower */
  .doodle-star {
    top: 88%;
    left: 5%;
    opacity: 0.26;
    transform: rotate(12deg);
  }

  /* D13: Map — center area */
  .doodle-map {
    top: 93%;
    left: 35%;
    opacity: 0.25;
    transform: rotate(-3deg);
  }

  /* D14: Monitor — right side, lower */
  .doodle-monitor {
    top: 91%;
    right: 30%;
    opacity: 0.24;
    transform: rotate(5deg);
  }

  /* D15: Paper plane — left side */
  .doodle-paper-plane {
    top: 96%;
    left: 20%;
    opacity: 0.24;
    transform: rotate(20deg);
  }

  /* ── Subtle float animations (desktop only) ─────── */
  @media (prefers-reduced-motion: no-preference) {
    .doodle-atom    { animation: df-a 14s ease-in-out infinite; }
    .doodle-beaker  { animation: df-b 12s ease-in-out infinite 3s; }
    .doodle-globe   { animation: df-c 16s ease-in-out infinite 1s; }
    .doodle-book    { animation: df-a 18s ease-in-out infinite 5s; }
    .doodle-cap     { animation: df-b 15s ease-in-out infinite 2s; }

    @keyframes df-a {
      0%, 100% { transform: translateY(0) rotate(-5deg); }
      50%       { transform: translateY(-5px) rotate(-3deg); }
    }
    @keyframes df-b {
      0%, 100% { transform: translateY(0) rotate(5deg); }
      50%       { transform: translateY(-6px) rotate(7deg); }
    }
    @keyframes df-c {
      0%, 100% { transform: translateY(0) rotate(4deg); }
      50%       { transform: translateY(-4px) rotate(6deg); }
    }
  }

  /* ── Tablet (640px – 1023px): 6-10 doodles ──────── */
  @media (max-width: 1023px) and (min-width: 640px) {
    .doodle-atom    { top: 10%; left: 2%; opacity: 0.30; transform: scale(0.85); }
    .doodle-beaker  { top: 6%; right: 3%; opacity: 0.26; transform: scale(0.8) rotate(6deg); }
    .doodle-globe   { top: 24%; right: 2%; opacity: 0.26; transform: scale(0.8); }
    .doodle-book    { top: 44%; right: 2%; opacity: 0.24; transform: scale(0.8) rotate(-4deg); }
    .doodle-code    { top: 60%; left: 2%; opacity: 0.24; transform: scale(0.8); }
    .doodle-compass { top: 65%; right: 4%; opacity: 0.22; transform: scale(0.8) rotate(-6deg); }
    .doodle-cap     { top: 78%; left: 1%; opacity: 0.22; transform: scale(0.75) rotate(4deg); }
    .doodle-pencil  { top: 85%; right: 2%; opacity: 0.20; transform: scale(0.75) rotate(-12deg); }
    .doodle-star    { top: 92%; left: 5%; opacity: 0.20; transform: scale(0.75) rotate(10deg); }
    .doodle-map     { display: none; }
    .doodle-pi      { display: none; }
    .doodle-monitor { display: none; }
    .doodle-paper-plane { display: none; }
    .doodle-triangle { display: none; }
    .doodle-ruler   { display: none; }
  }

  /* ── Mobile (< 640px): 3-5 doodles only ─────────── */
  @media (max-width: 639px) {
    .doodle-atom   { top: 8%; left: 2%; opacity: 0.24; transform: scale(0.7); }
    .doodle-globe  { top: 22%; right: 3%; opacity: 0.22; transform: scale(0.65); }
    .doodle-book   { top: 42%; left: 2%; opacity: 0.20; transform: scale(0.65) rotate(-4deg); }
    .doodle-code   { top: 60%; right: 3%; opacity: 0.20; transform: scale(0.65) rotate(8deg); }
    .doodle-cap    { top: 78%; left: 3%; opacity: 0.18; transform: scale(0.6) rotate(3deg); }
    /* Hide remaining doodles on mobile to keep it clean */
    .doodle-beaker,
    .doodle-triangle,
    .doodle-ruler,
    .doodle-compass,
    .doodle-pencil,
    .doodle-star,
    .doodle-map,
    .doodle-monitor,
    .doodle-paper-plane,
    .doodle-pi {
      display: none;
    }
  }

  /* ── Reduced motion: no animations ─────────────── */
  @media (prefers-reduced-motion: reduce) {
    .doodle-atom,
    .doodle-beaker,
    .doodle-globe,
    .doodle-book,
    .doodle-cap {
      animation: none;
    }
  }
</style>