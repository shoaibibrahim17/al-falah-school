---
/**
 * AcademicBackgroundDoodles.astro
 * Pencil-sketch academic doodle background layer.
 * Fixed position across viewport — renders behind all page content.
 * Hero section is visually excluded due to its own background/overlay layers.
 *
 * CMS: NOT managed — code-only decorative asset.
 * 24 doodles on desktop, 10 on tablet, 5 on mobile.
 */

const STROKE = "rgba(30, 41, 59, 0.45)";
const STROKE_LIGHT = "rgba(30, 41, 59, 0.25)";
const STROKE_GREEN = "rgba(15, 100, 55, 0.35)";
const STROKE_GREEN_LIGHT = "rgba(15, 100, 55, 0.18)";
---

<div class="doodle-layer" aria-hidden="true" role="presentation">
  <!-- 1. Open Book -->
  <div class="doodle doodle-book">
    <svg width="44" height="44" viewBox="0 0 52 52" fill="none">
      <path d="M26 44V10" stroke={STROKE} stroke-width="1.4" stroke-linecap="round"/>
      <path d="M26 10C20 10 14 12 10 14C6 16 4 19 4 23C4 28 8 32 13 34C18 36 26 38 26 38" stroke={STROKE} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M26 10C32 10 38 12 42 14C46 16 48 19 48 23C48 28 44 32 39 34C34 36 26 38 26 38" stroke={STROKE} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 20H18M9 25H17M10 30H16" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <path d="M42 20H34M43 25H35M42 30H36" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 2. Pencil -->
  <div class="doodle doodle-pencil">
    <svg width="26" height="110" viewBox="0 0 26 110" fill="none">
      <path d="M8 100L4 104L2 102L6 98L8 100Z" stroke={STROKE} stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M8 100L20 18L24 14L14 104L8 100Z" stroke={STROKE} stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M20 18L18 10L24 14" stroke={STROKE} stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M11 80L15 50" stroke={STROKE_LIGHT} stroke-width="0.8" stroke-linecap="round"/>
      <path d="M13 82L17 52" stroke={STROKE_LIGHT} stroke-width="0.8" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 3. Ruler -->
  <div class="doodle doodle-ruler">
    <svg width="80" height="24" viewBox="0 0 80 24" fill="none">
      <rect x="2" y="2" width="76" height="20" rx="3" stroke={STROKE} stroke-width="1.3"/>
      <path d="M8 2V10M16 2V8M24 2V10M32 2V8M40 2V10M48 2V8M56 2V10M64 2V8" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <path d="M8 22V14M16 22V16M24 22V14M32 22V16M40 22V14M48 22V16M56 22V14M64 22V16" stroke={STROKE_LIGHT} stroke-width="0.8" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 4. Triangle (Set Square) -->
  <div class="doodle doodle-triangle">
    <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
      <path d="M6 42L24 8L42 42H6Z" stroke={STROKE} stroke-width="1.4" stroke-linejoin="round"/>
      <path d="M10 38L14 34M16 31L20 27M22 24L26 20M28 17L32 13" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <path d="M10 36H18M9 39H15" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 5. Globe -->
  <div class="doodle doodle-globe">
    <svg width="36" height="36" viewBox="0 0 44 44" fill="none">
      <circle cx="22" cy="22" r="17" stroke={STROKE_GREEN} stroke-width="1.4"/>
      <ellipse cx="22" cy="22" rx="17" ry="7" stroke={STROKE_GREEN_LIGHT} stroke-width="1"/>
      <ellipse cx="22" cy="22" rx="7" ry="17" stroke={STROKE_GREEN_LIGHT} stroke-width="1"/>
      <path d="M5 22H39" stroke={STROKE_GREEN_LIGHT} stroke-width="0.9"/>
      <path d="M22 13C19.5 13 17.5 14.8 17.5 16.9C17.5 20 22 25 22 25C22 25 26.5 20 26.5 16.9C26.5 14.8 24.5 13 22 13Z" stroke={STROKE_GREEN} stroke-width="1.2" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- 6. Science Flask -->
  <div class="doodle doodle-flask">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <path d="M10 4H18V10L23 22C23.5 23.5 22.5 25 21 25H7C5.5 25 4.5 23.5 5 22L10 10V4Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M10 4H18" stroke={STROKE} stroke-width="1.3" stroke-linecap="round"/>
      <path d="M7.5 20C7.5 20 9 18 14 18C19 18 20.5 20 20.5 20" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <circle cx="9" cy="17" r="1.2" stroke={STROKE_LIGHT} stroke-width="0.9"/>
      <circle cx="12" cy="15" r="1.2" stroke={STROKE_LIGHT} stroke-width="0.9"/>
      <circle cx="16" cy="16" r="1.2" stroke={STROKE_LIGHT} stroke-width="0.9"/>
    </svg>
  </div>

  <!-- 7. Atom -->
  <div class="doodle doodle-atom">
    <svg width="28" height="28" viewBox="0 0 40 40" fill="none">
      <circle cx="20" cy="20" r="3" stroke={STROKE} stroke-width="1.3"/>
      <ellipse cx="20" cy="20" rx="16" ry="7" stroke={STROKE_LIGHT} stroke-width="1.1" transform="rotate(0 20 20)"/>
      <ellipse cx="20" cy="20" rx="16" ry="7" stroke={STROKE_LIGHT} stroke-width="1.1" transform="rotate(60 20 20)"/>
      <ellipse cx="20" cy="20" rx="16" ry="7" stroke={STROKE_LIGHT} stroke-width="1.1" transform="rotate(120 20 20)"/>
      <circle cx="4" cy="16" r="1.5" stroke={STROKE_LIGHT} stroke-width="1"/>
      <circle cx="30" cy="33" r="1.5" stroke={STROKE_LIGHT} stroke-width="1"/>
    </svg>
  </div>

  <!-- 8. Code Brackets -->
  <div class="doodle doodle-code">
    <svg width="24" height="24" viewBox="0 0 28 28" fill="none">
      <path d="M18 6L10 14L18 22" stroke={STROKE_GREEN} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 6L18 14L10 22" stroke={STROKE_GREEN} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- 9. Paper Plane -->
  <div class="doodle doodle-plane">
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
      <path d="M3 14L25 3L13 25L11 15L3 14Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M3 14L13 25" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <path d="M3 14L25 3L11 15" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- 10. Star -->
  <div class="doodle doodle-star">
    <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
      <path d="M14 3L16.9 10.6L25 11.3L18.7 16.5L20.5 24.3L14 20L7.5 24.3L9.3 16.5L3 11.3L11.1 10.6L14 3Z"
        stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- 11. Graduation Cap -->
  <div class="doodle doodle-cap">
    <svg width="30" height="30" viewBox="0 0 40 40" fill="none">
      <path d="M20 5L5 13L20 21L35 13L20 5Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M8 15H32V22C32 26.4 29.2 30 26 31.5C24.5 32.3 23 32.8 21 32.8C19 32.8 17.5 32.3 16 31.5C12.8 30 10 26.4 10 22V15Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M20 21V30" stroke={STROKE} stroke-width="1.1" stroke-linecap="round"/>
      <circle cx="20" cy="32" r="1.8" stroke={STROKE} stroke-width="1"/>
    </svg>
  </div>

  <!-- 12. Calculator -->
  <div class="doodle doodle-calc">
    <svg width="24" height="32" viewBox="0 0 30 38" fill="none">
      <rect x="3" y="2" width="24" height="34" rx="3" stroke={STROKE} stroke-width="1.3"/>
      <rect x="5" y="4" width="20" height="10" rx="1.5" stroke={STROKE_LIGHT} stroke-width="1"/>
      <path d="M8 20H22M8 25H22M8 30H22" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
      <path d="M8 5H22V12H8V5Z" stroke={STROKE_LIGHT} stroke-width="0.8"/>
      <text x="11" y="10" font-size="6" fill={STROKE} font-family="sans-serif" font-weight="bold">+</text>
      <text x="19" y="10" font-size="6" fill={STROKE} font-family="sans-serif" font-weight="bold">−</text>
    </svg>
  </div>

  <!-- 13. Microscope -->
  <div class="doodle doodle-microscope">
    <svg width="24" height="32" viewBox="0 0 30 38" fill="none">
      <path d="M15 28V18M15 18C15 18 12 12 10 8C8 6 6 6 6 8C6 10 8 14 10 16L12 18" stroke={STROKE} stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M15 18L18 16C18 16 20 14 20 10C20 6 18 4 16 4C14 4 12 6 12 10" stroke={STROKE} stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 28H20" stroke={STROKE} stroke-width="1.2" stroke-linecap="round"/>
      <path d="M8 32H22" stroke={STROKE} stroke-width="1.2" stroke-linecap="round"/>
      <circle cx="16" cy="8" r="2" stroke={STROKE_LIGHT} stroke-width="1"/>
    </svg>
  </div>

  <!-- 14. Light Bulb -->
  <div class="doodle doodle-bulb">
    <svg width="22" height="28" viewBox="0 0 28 34" fill="none">
      <path d="M14 2C8 2 5 7 5 12C5 17 8 20 10 22V26C10 27 11 28 12 28H16C17 28 18 27 18 26V22C20 20 23 17 23 12C23 7 20 2 14 2Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M12 28V30M16 28V30M14 30V32" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <path d="M11 16C11 16 12 18 14 18C16 18 17 16 17 16" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
      <path d="M10 9C11 7 13 6 14 6" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 15. School Bag -->
  <div class="doodle doodle-bag">
    <svg width="26" height="28" viewBox="0 0 30 34" fill="none">
      <path d="M8 12V8C8 5 10 3 13 3H17C20 3 22 5 22 8V12" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <rect x="3" y="10" width="24" height="20" rx="3" stroke={STROKE} stroke-width="1.3"/>
      <path d="M3 18H27" stroke={STROKE_LIGHT} stroke-width="0.9"/>
      <rect x="12" y="14" width="6" height="4" rx="1" stroke={STROKE_LIGHT} stroke-width="0.9"/>
    </svg>
  </div>

  <!-- 16. Notebook -->
  <div class="doodle doodle-notebook">
    <svg width="22" height="28" viewBox="0 0 26 34" fill="none">
      <rect x="4" y="2" width="18" height="30" rx="2" stroke={STROKE} stroke-width="1.3"/>
      <path d="M4 8H22M4 15H22M4 22H22" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
      <path d="M2 4V30" stroke={STROKE} stroke-width="1.3" stroke-linecap="round"/>
      <circle cx="2" cy="17" r="1.5" stroke={STROKE_LIGHT} stroke-width="0.9"/>
    </svg>
  </div>

  <!-- 17. Trophy -->
  <div class="doodle doodle-trophy">
    <svg width="22" height="28" viewBox="0 0 28 34" fill="none">
      <path d="M9 28H19" stroke={STROKE} stroke-width="1.3" stroke-linecap="round"/>
      <path d="M14 28V22" stroke={STROKE} stroke-width="1.3" stroke-linecap="round"/>
      <path d="M8 6H20V12C20 16 17 20 14 20C11 20 8 16 8 12V6Z" stroke={STROKE} stroke-width="1.3" stroke-linejoin="round"/>
      <path d="M8 6C8 4 6 3 4 3C3 3 3 4 3 5V6C3 9 5 11 8 11" stroke={STROKE_LIGHT} stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M20 6C20 4 22 3 24 3C25 3 25 4 25 5V6C25 9 23 11 20 11" stroke={STROKE_LIGHT} stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 12L14 14L18 12" stroke={STROKE_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 18. Map Pin -->
  <div class="doodle doodle-pin">
    <svg width="20" height="28" viewBox="0 0 24 32" fill="none">
      <path d="M12 2C7 2 4 6 4 10C4 16 12 28 12 28C12 28 20 16 20 10C20 6 17 2 12 2Z" stroke={STROKE_GREEN} stroke-width="1.3" stroke-linejoin="round"/>
      <circle cx="12" cy="10" r="3" stroke={STROKE_GREEN_LIGHT} stroke-width="1.1"/>
    </svg>
  </div>

  <!-- 19. Leaf -->
  <div class="doodle doodle-leaf">
    <svg width="22" height="28" viewBox="0 0 26 34" fill="none">
      <path d="M13 32V6" stroke={STROKE_GREEN} stroke-width="1.3" stroke-linecap="round"/>
      <path d="M13 6C8 6 3 10 2 16C1 22 5 25 13 6Z" stroke={STROKE_GREEN} stroke-width="1.2" stroke-linejoin="round"/>
      <path d="M13 6C18 6 23 10 24 16C25 22 21 25 13 6Z" stroke={STROKE_GREEN} stroke-width="1.2" stroke-linejoin="round"/>
      <path d="M8 14L13 10L18 14" stroke={STROKE_GREEN_LIGHT} stroke-width="0.9" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 20. ABC -->
  <div class="doodle doodle-abc">
    <svg width="42" height="20" viewBox="0 0 60 26" fill="none">
      <text x="2" y="20" font-size="20" fill={STROKE} font-family="sans-serif" font-weight="bold">ABC</text>
    </svg>
  </div>

  <!-- 21. 123 -->
  <div class="doodle doodle-nums">
    <svg width="36" height="20" viewBox="0 0 50 26" fill="none">
      <text x="2" y="20" font-size="18" fill={STROKE} font-family="sans-serif" font-weight="bold">123</text>
    </svg>
  </div>

  <!-- 22. Compass -->
  <div class="doodle doodle-compass">
    <svg width="26" height="26" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="16" r="13" stroke={STROKE} stroke-width="1.3"/>
      <circle cx="16" cy="16" r="3" stroke={STROKE} stroke-width="1.1"/>
      <path d="M16 3L17.8 13.2H14.2L16 3Z" stroke={STROKE} stroke-width="1.1" stroke-linejoin="round"/>
      <path d="M16 29L14.2 18.8H17.8L16 29Z" stroke={STROKE} stroke-width="1.1" stroke-linejoin="round"/>
      <path d="M16 3V5M16 27V29M3 16H5M27 16H29" stroke={STROKE_LIGHT} stroke-width="1.2" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 23. Pi Symbol -->
  <div class="doodle doodle-pi">
    <svg width="20" height="20" viewBox="0 0 26 26" fill="none">
      <text x="0" y="22" font-size="22" fill={STROKE} font-family="serif" font-style="italic">π</text>
      <path d="M3 24H23" stroke={STROKE_LIGHT} stroke-width="1.2" stroke-linecap="round"/>
    </svg>
  </div>

  <!-- 24. Math Symbols -->
  <div class="doodle doodle-math">
    <svg width="30" height="24" viewBox="0 0 40 30" fill="none">
      <path d="M6 10L14 18M14 10L6 18" stroke={STROKE} stroke-width="1.3" stroke-linecap="round"/>
      <path d="M22 14H34" stroke={STROKE} stroke-width="1.3" stroke-linecap="round"/>
      <path d="M28 8V20" stroke={STROKE} stroke-width="1.3" stroke-linecap="round"/>
      <path d="M6 24L10 24M14 24H10M10 24V20M10 24V28" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
      <path d="M22 24L34 24" stroke={STROKE_LIGHT} stroke-width="1" stroke-linecap="round"/>
    </svg>
  </div>
</div>

<style>
  .doodle-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    user-select: none;
    -webkit-user-select: none;
    overflow: hidden;
    z-index: 0;
  }

  .doodle {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Desktop positions (24 doodles) ─────────── */
  .doodle-book     { top: 5%;   left: 5%;  opacity: 0.85; transform: rotate(-3deg); }
  .doodle-pencil   { top: 8%;   right: 6%; opacity: 0.70; transform: rotate(12deg); }
  .doodle-ruler    { top: 14%;  left: 2%;  opacity: 0.75; transform: rotate(-8deg); }
  .doodle-triangle { top: 20%;  right: 4%; opacity: 0.70; transform: rotate(6deg); }
  .doodle-globe    { top: 26%;  left: 3%;  opacity: 0.75; transform: rotate(-2deg); }
  .doodle-flask    { top: 32%;  right: 5%; opacity: 0.70; transform: rotate(10deg); }
  .doodle-atom     { top: 38%;  left: 2%;  opacity: 0.65; transform: rotate(-6deg); }
  .doodle-code     { top: 44%;  right: 4%; opacity: 0.90; }
  .doodle-plane    { top: 50%;  left: 2%;  opacity: 0.70; transform: rotate(18deg); }
  .doodle-star     { top: 49%;  right: 2%; opacity: 0.80; }
  .doodle-cap      { top: 54%;  left: 4%;  opacity: 0.70; transform: rotate(4deg); }
  .doodle-calc     { top: 60%;  right: 3%; opacity: 0.75; transform: rotate(-5deg); }
  .doodle-microscope { top: 64%; left: 2%; opacity: 0.70; }
  .doodle-bulb     { top: 70%;  right: 5%; opacity: 0.70; transform: rotate(8deg); }
  .doodle-bag      { top: 76%;  left: 2%;  opacity: 0.65; transform: rotate(-10deg); }
  .doodle-notebook { top: 82%;  right: 5%; opacity: 0.70; transform: rotate(3deg); }
  .doodle-trophy   { top: 86%;  left: 4%;  opacity: 0.75; }
  .doodle-pin      { top: 88%;  right: 2%; opacity: 0.85; }
  .doodle-leaf     { top: 92%;  left: 2%;  opacity: 0.75; transform: rotate(-15deg); }
  .doodle-abc      { top: 10%;  left: 45%; opacity: 0.60; }
  .doodle-nums     { top: 34%;  left: 55%; opacity: 0.60; }
  .doodle-compass  { top: 72%;  left: 40%; opacity: 0.70; transform: rotate(5deg); }
  .doodle-pi       { top: 52%;  left: 60%; opacity: 0.70; }
  .doodle-math     { top: 78%;  left: 50%; opacity: 0.65; }

  /* ── Tablet (640px – 1023px): ~10 doodles ──── */
  @media (max-width: 1023px) and (min-width: 640px) {
    .doodle-book     { top: 6%;   left: 4%;  opacity: 0.75; transform: scale(0.85) rotate(-3deg); }
    .doodle-pencil   { top: 10%;  right: 5%; opacity: 0.55; transform: scale(0.8) rotate(10deg); }
    .doodle-ruler    { top: 16%;  left: 2%;  opacity: 0.60; transform: scale(0.85) rotate(-6deg); }
    .doodle-triangle { top: 22%;  right: 4%; opacity: 0.60; transform: scale(0.8) rotate(5deg); }
    .doodle-globe    { top: 28%;  left: 3%;  opacity: 0.60; transform: scale(0.8) rotate(-2deg); }
    .doodle-atom     { top: 40%;  left: 2%;  opacity: 0.55; transform: scale(0.75); }
    .doodle-cap      { top: 56%;  left: 4%;  opacity: 0.55; transform: scale(0.75) rotate(3deg); }
    .doodle-notebook { top: 84%;  right: 4%; opacity: 0.55; transform: scale(0.75) rotate(2deg); }
    .doodle-leaf     { top: 92%;  left: 2%;  opacity: 0.60; transform: scale(0.75) rotate(-12deg); }
    .doodle-abc      { top: 34%;  left: 45%; opacity: 0.50; transform: scale(0.8); }
    .doodle-nums     { display: none; }
    .doodle-flask    { display: none; }
    .doodle-code     { display: none; }
    .doodle-plane    { display: none; }
    .doodle-star     { display: none; }
    .doodle-calc     { display: none; }
    .doodle-microscope { display: none; }
    .doodle-bulb     { display: none; }
    .doodle-bag      { display: none; }
    .doodle-trophy   { display: none; }
    .doodle-pin      { display: none; }
    .doodle-compass  { display: none; }
    .doodle-pi       { display: none; }
    .doodle-math     { display: none; }
  }

  /* ── Mobile (< 640px): 5 doodles only ──────── */
  @media (max-width: 639px) {
    .doodle-book     { top: 8%;   left: 4%;  opacity: 0.55; transform: scale(0.65) rotate(-2deg); }
    .doodle-globe    { top: 28%;  left: 3%;  opacity: 0.50; transform: scale(0.6) rotate(-1deg); }
    .doodle-atom     { top: 42%;  left: 2%;  opacity: 0.48; transform: scale(0.55); }
    .doodle-cap      { top: 58%;  left: 5%;  opacity: 0.48; transform: scale(0.55) rotate(3deg); }
    .doodle-leaf     { top: 92%;  left: 3%;  opacity: 0.50; transform: scale(0.55) rotate(-10deg); }
    .doodle-pencil   { display: none; }
    .doodle-ruler    { display: none; }
    .doodle-triangle { display: none; }
    .doodle-flask    { display: none; }
    .doodle-code     { display: none; }
    .doodle-plane    { display: none; }
    .doodle-star     { display: none; }
    .doodle-calc     { display: none; }
    .doodle-microscope { display: none; }
    .doodle-bulb     { display: none; }
    .doodle-bag      { display: none; }
    .doodle-notebook { display: none; }
    .doodle-trophy   { display: none; }
    .doodle-pin      { display: none; }
    .doodle-compass  { display: none; }
    .doodle-pi       { display: none; }
    .doodle-math     { display: none; }
    .doodle-abc      { display: none; }
    .doodle-nums     { display: none; }
  }
</style>
