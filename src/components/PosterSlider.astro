---
import { Megaphone, GraduationCap, Sparkles, MessageSquare, Image as ImageIcon } from "lucide-astro";
import { SCHOOL } from "../data/school";

/* Filter posters the way the future Sanity fetch will:
   active === true AND featured === true AND inside date window.
   Cap at 3 for the homepage. Sorted by `order` ascending. */
const now = Date.now();
const posters = SCHOOL.posters
  .filter((p) => {
    if (!p.active || !p.featured) return false;
    if (p.startDate && Date.parse(p.startDate) > now) return false;
    if (p.endDate && Date.parse(p.endDate) <= now) return false;
    return true;
  })
  .sort((a, b) => a.order - b.order)
  .slice(0, 3);

const hasPosters = posters.length > 0;

/* Decorative placeholder palette/icon — used only when a poster has no image.
   Code controls the visual; CMS controls the content (title/alt). */
const iconFor: Record<string, typeof Megaphone> = {
  "admissions-enquiry-2026-27": GraduationCap,
  "school-activities": Sparkles,
  "parent-communication": MessageSquare,
};

const accentPalette = {
  "deep-green": "from-deep-green via-deep-green to-deep-green-dark",
  gold: "from-gold-dark via-gold to-gold-light",
} as const;
---

{hasPosters && (
  <section
    id="updates"
    class="relative py-14 lg:py-20 bg-ivory overflow-hidden"
    aria-label={SCHOOL.updates.eyebrow}
  >
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 right-1/3 w-72 h-72 rounded-full bg-deep-green/[0.04] blur-3xl"></div>
      <div class="absolute bottom-0 left-1/4 w-72 h-72 rounded-full bg-gold/[0.05] blur-3xl"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header (kept compact — image is the focus) -->
      <div class="text-center max-w-2xl mx-auto mb-7 lg:mb-10">
        <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-3">
          <Megaphone class="w-3.5 h-3.5" />
          {SCHOOL.updates.eyebrow}
        </div>
        <h2 data-reveal class="text-2xl sm:text-3xl lg:text-4xl font-bold text-charcoal leading-tight tracking-tight">
          {SCHOOL.updates.heading}
        </h2>
      </div>

      <!-- Slider -->
      <div
        data-reveal="fade"
        class="poster-slider relative"
        data-poster-slider
        data-interval="4500"
        data-count={posters.length}
      >
        <!-- Outer premium frame: ivory card, gold corner gradient, soft shadow -->
        <div class="poster-frame relative">
          <!-- Track / stage -->
          <div class="poster-stage relative aspect-[16/10] sm:aspect-[16/9] md:aspect-[21/9] overflow-hidden rounded-[1.25rem]">
            {posters.map((p, i) => {
              const Icon = iconFor[p._id] ?? ImageIcon;
              const accent = accentPalette[p.accent] ?? accentPalette["deep-green"];
              const hasImage = Boolean(p.image);
              return (
                <article
                  class="poster-slide"
                  data-poster-slide
                  data-index={i}
                  aria-hidden={i === 0 ? "false" : "true"}
                  aria-roledescription="slide"
                  aria-label={`${i + 1} of ${posters.length}: ${p.title}`}
                >
                  {hasImage ? (
                    <img
                      src={p.image ?? ""}
                      alt={p.imageAlt}
                      class="poster-image"
                      loading={i === 0 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  ) : (
                    <!-- Decorative placeholder — premium gradient block, not an ad banner -->
                    <div
                      class={`poster-placeholder bg-gradient-to-br ${accent}`}
                      role="img"
                      aria-label={p.imageAlt}
                    >
                      <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.10)_1px,transparent_1px)] [background-size:22px_22px] opacity-50"></div>
                      <div class="absolute -top-14 -right-14 w-56 h-56 rounded-full bg-white/15 blur-3xl breathe-slow"></div>
                      <div class="absolute -bottom-14 -left-14 w-52 h-52 rounded-full bg-white/10 blur-3xl breathe-slow delay"></div>

                      <div class="absolute inset-0 flex items-center justify-center">
                        <div class="relative">
                          <div class="absolute inset-0 -m-3 rounded-3xl bg-white/15 blur-xl"></div>
                          <div class="relative w-20 h-20 sm:w-24 sm:h-24 rounded-3xl bg-white/95 backdrop-blur-sm flex items-center justify-center shadow-xl shadow-charcoal/30">
                            <Icon class="w-10 h-10 sm:w-12 sm:h-12 text-deep-green" />
                          </div>
                        </div>
                      </div>

                      <!-- Brand mark in corner so the placeholder still feels institutional -->
                      <div class="absolute top-4 left-4 text-white/85 text-[10px] font-semibold tracking-[0.22em] uppercase">
                        {SCHOOL.shortName} · {SCHOOL.updates.eyebrow}
                      </div>
                    </div>
                  )}

                  <!-- Title/description kept for screen readers only — frontend visual is image-led -->
                  <span class="sr-only">{p.title}. {p.description}</span>
                </article>
              );
            })}
          </div>

          {posters.length > 1 && (
            <>
              <button
                type="button"
                class="poster-nav poster-nav-prev"
                data-poster-prev
                aria-label="Previous announcement"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m15 18-6-6 6-6"/>
                </svg>
              </button>
              <button
                type="button"
                class="poster-nav poster-nav-next"
                data-poster-next
                aria-label="Next announcement"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </button>
            </>
          )}
        </div>

        {posters.length > 1 && (
          <div class="mt-4 sm:mt-5 flex items-center justify-center">
            <div class="poster-dots flex items-center gap-2" role="tablist" aria-label="Choose announcement">
              {posters.map((p, i) => (
                <button
                  type="button"
                  class="poster-dot"
                  role="tab"
                  data-poster-dot
                  data-index={i}
                  aria-selected={i === 0 ? "true" : "false"}
                  aria-label={`Show announcement ${i + 1}: ${p.title}`}
                >
                  <span class="poster-dot-fill"></span>
                </button>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <script>
      (() => {
        const root = document.querySelector<HTMLElement>("[data-poster-slider]");
        if (!root) return;

        const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-poster-slide]"));
        const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-poster-dot]"));
        const prevBtn = root.querySelector<HTMLButtonElement>("[data-poster-prev]");
        const nextBtn = root.querySelector<HTMLButtonElement>("[data-poster-next]");
        if (slides.length <= 1) return;

        const interval = Number(root.dataset.interval ?? 4500);
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        let activeIndex = 0;
        let timerId: number | null = null;
        let paused = false;

        const setActive = (next: number) => {
          const target = ((next % slides.length) + slides.length) % slides.length;
          slides.forEach((slide, i) => {
            const isActive = i === target;
            slide.classList.toggle("is-active", isActive);
            slide.setAttribute("aria-hidden", isActive ? "false" : "true");
          });
          dots.forEach((dot, i) => {
            const isActive = i === target;
            dot.classList.toggle("is-active", isActive);
            dot.setAttribute("aria-selected", isActive ? "true" : "false");
          });
          activeIndex = target;
        };

        const stop = () => {
          if (timerId !== null) {
            window.clearTimeout(timerId);
            timerId = null;
          }
        };

        const tick = () => {
          stop();
          if (prefersReducedMotion || paused) return;
          timerId = window.setTimeout(() => {
            setActive(activeIndex + 1);
            tick();
          }, interval);
        };

        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => {
            setActive(i);
            tick();
          });
        });
        prevBtn?.addEventListener("click", () => {
          setActive(activeIndex - 1);
          tick();
        });
        nextBtn?.addEventListener("click", () => {
          setActive(activeIndex + 1);
          tick();
        });

        root.addEventListener("pointerenter", () => {
          paused = true;
          stop();
        });
        root.addEventListener("pointerleave", () => {
          paused = false;
          tick();
        });
        root.addEventListener("focusin", () => {
          paused = true;
          stop();
        });
        root.addEventListener("focusout", (e) => {
          if (!root.contains(e.relatedTarget as Node | null)) {
            paused = false;
            tick();
          }
        });

        root.addEventListener("keydown", (e) => {
          if (e.key === "ArrowRight") {
            setActive(activeIndex + 1);
            tick();
          } else if (e.key === "ArrowLeft") {
            setActive(activeIndex - 1);
            tick();
          }
        });

        document.addEventListener("visibilitychange", () => {
          if (document.hidden) stop();
          else tick();
        });

        /* Touch swipe (mobile) */
        let touchStartX = 0;
        let touchStartY = 0;
        root.addEventListener(
          "touchstart",
          (e) => {
            touchStartX = e.touches[0].clientX;
            touchStartY = e.touches[0].clientY;
          },
          { passive: true }
        );
        root.addEventListener(
          "touchend",
          (e) => {
            const dx = e.changedTouches[0].clientX - touchStartX;
            const dy = e.changedTouches[0].clientY - touchStartY;
            if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
              setActive(activeIndex + (dx < 0 ? 1 : -1));
              tick();
            }
          },
          { passive: true }
        );

        setActive(0);
        tick();
      })();
    </script>
  </section>
)}
