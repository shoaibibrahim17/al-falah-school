---
import { Megaphone, GraduationCap, MessageSquare, Image as ImageIcon } from "lucide-astro";
import { SCHOOL } from "../data/school";
import { assetUrl } from "../utils/assetUrl";

/* Filter posters the way the future Sanity fetch will:
   active === true AND featured === true AND inside date window.
   Cap at 3 for the homepage. Sorted by `order` ascending. */
const now = Date.now();
const posters = SCHOOL.posters
  .filter((p) => {
    if (!p.active || !p.featured) return false;
    if (p.startDate && Date.parse(p.startDate) > now) return false;
    if (p.endDate && Date.parse(p.endDate) <= now) return false;
    return true;
  })
  .sort((a, b) => a.order - b.order)
  .slice(0, 3);

const hasPosters = posters.length > 0;

/* Decorative icon per poster — used only when no image is set.
   Simple, consistent styling. */
const iconFor: Record<string, typeof Megaphone> = {
  "admissions-enquiry-2026-27": GraduationCap,
  "school-office-hours": MessageSquare,
  "parent-communication": MessageSquare,
};

const accentPalette = {
  "deep-green": "from-deep-green via-deep-green to-deep-green-dark",
  "green-light": "from-deep-green-light via-deep-green to-deep-green-dark",
} as const;
---

{hasPosters && (
  <section
    id="updates"
    class="relative py-10 sm:py-12 lg:py-14 bg-white overflow-hidden"
    aria-label={SCHOOL.updates.eyebrow}
  >
    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="text-center max-w-lg mx-auto mb-5 lg:mb-7">
        <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-[11px] font-semibold uppercase tracking-wider mb-3">
          <Megaphone class="w-3.5 h-3.5" />
          {SCHOOL.updates.eyebrow}
        </div>
        <h2 data-reveal class="text-2xl sm:text-3xl lg:text-[2.35rem] font-bold text-charcoal leading-tight tracking-tight">
          {SCHOOL.updates.heading}
        </h2>
      </div>

      <!-- Poster slider -->
      <div
        data-reveal="fade"
        class="poster-slider relative"
        data-poster-slider
        data-interval="2500"
        data-count={posters.length}
      >
        <div class="poster-frame relative">
          <!-- Slide track -->
          <div class="poster-stage relative overflow-hidden rounded-xl">
            {posters.map((p, i) => {
              const Icon = iconFor[p._id] ?? ImageIcon;
              const accent = accentPalette[p.accent] ?? accentPalette["deep-green"];
              const hasImage = Boolean(p.image);
              return (
                <article
                  class={`poster-slide ${i === 0 ? "is-active" : ""}`}
                  data-poster-slide
                  data-index={i}
                  aria-hidden={i === 0 ? "false" : "true"}
                  aria-roledescription="slide"
                  aria-label={`${i + 1} of ${posters.length}: ${p.title}`}
                >
                  {hasImage ? (
                    <img
                      src={assetUrl(p.image)}
                      alt={p.imageAlt}
                      class="poster-image"
                      loading={i === 0 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  ) : (
                    /* Poster placeholder — clean gradient block */
                    <div
                      class={`poster-placeholder bg-gradient-to-br ${accent}`}
                      role="img"
                      aria-label={p.imageAlt}
                    >
                      <!-- Subtle dot pattern -->
                      <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.10)_1px,transparent_1px)] [background-size:22px_22px] opacity-50"></div>

                      <!-- Center icon -->
                      <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-white/10 backdrop-blur-sm flex items-center justify-center shadow-lg">
                          <Icon class="w-8 h-8 sm:w-10 sm:h-10 text-white" />
                        </div>
                      </div>

                      <!-- Brand in corner -->
                      <div class="absolute top-4 left-4 text-white/80 text-[10px] font-semibold tracking-[0.20em] uppercase">
                        {SCHOOL.shortName}
                      </div>
                    </div>
                  )}

                  <!-- Screen reader text -->
                  <span class="sr-only">{p.title}. {p.description}</span>
                </article>
              );
            })}
          </div>

          {/* Navigation arrows */}
          {posters.length > 1 && (
            <>
              <button
                type="button"
                class="poster-nav poster-nav-prev"
                data-poster-prev
                aria-label="Previous announcement"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m15 18-6-6 6-6"/>
                </svg>
              </button>
              <button
                type="button"
                class="poster-nav poster-nav-next"
                data-poster-next
                aria-label="Next announcement"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </button>
            </>
          )}
        </div>

        {/* Dot indicators */}
        {posters.length > 1 && (
          <div class="mt-4 sm:mt-5 flex items-center justify-center">
            <div class="poster-dots flex items-center gap-2" role="tablist" aria-label="Choose announcement">
              {posters.map((p, i) => (
                <button
                  type="button"
                  class="poster-dot"
                  role="tab"
                  data-poster-dot
                  data-index={i}
                  aria-selected={i === 0 ? "true" : "false"}
                  aria-label={`Show announcement ${i + 1}: ${p.title}`}
                />
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <script>
      (() => {
        const root = document.querySelector<HTMLElement>("[data-poster-slider]");
        if (!root) return;

        const slides = Array.from(root.querySelectorAll<HTMLElement>("[data-poster-slide]"));
        const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-poster-dot]"));
        const prevBtn = root.querySelector<HTMLButtonElement>("[data-poster-prev]");
        const nextBtn = root.querySelector<HTMLButtonElement>("[data-poster-next]");
        if (slides.length <= 1) return;

        const interval = Number(root.dataset.interval ?? 4500);
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        let activeIndex = 0;
        let timerId: number | null = null;
        let paused = false;

        const setActive = (next: number) => {
          const target = ((next % slides.length) + slides.length) % slides.length;
          slides.forEach((slide, i) => {
            const isActive = i === target;
            slide.classList.toggle("is-active", isActive);
            slide.setAttribute("aria-hidden", isActive ? "false" : "true");
          });
          dots.forEach((dot, i) => {
            const isActive = i === target;
            dot.classList.toggle("is-active", isActive);
            dot.setAttribute("aria-selected", isActive ? "true" : "false");
          });
          activeIndex = target;
        };

        const stop = () => {
          if (timerId !== null) {
            window.clearTimeout(timerId);
            timerId = null;
          }
        };

        const tick = () => {
          stop();
          if (paused) return;
          timerId = window.setTimeout(() => {
            setActive(activeIndex + 1);
            tick();
          }, interval);
        };

        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => {
            setActive(i);
            tick();
          });
        });
        prevBtn?.addEventListener("click", () => {
          setActive(activeIndex - 1);
          tick();
        });
        nextBtn?.addEventListener("click", () => {
          setActive(activeIndex + 1);
          tick();
        });

        root.addEventListener("pointerenter", () => {
          paused = true;
          stop();
        });
        root.addEventListener("pointerleave", () => {
          paused = false;
          tick();
        });
        root.addEventListener("focusin", () => {
          paused = true;
          stop();
        });
        root.addEventListener("focusout", (e) => {
          if (!root.contains(e.relatedTarget as Node | null)) {
            paused = false;
            tick();
          }
        });

        root.addEventListener("keydown", (e) => {
          if (e.key === "ArrowRight") {
            setActive(activeIndex + 1);
            tick();
          } else if (e.key === "ArrowLeft") {
            setActive(activeIndex - 1);
            tick();
          }
        });

        document.addEventListener("visibilitychange", () => {
          if (document.hidden) stop();
          else tick();
        });

        /* Touch swipe */
        let touchStartX = 0;
        let touchStartY = 0;
        root.addEventListener(
          "touchstart",
          (e) => {
            touchStartX = e.touches[0].clientX;
            touchStartY = e.touches[0].clientY;
          },
          { passive: true }
        );
        root.addEventListener(
          "touchend",
          (e) => {
            const dx = e.changedTouches[0].clientX - touchStartX;
            const dy = e.changedTouches[0].clientY - touchStartY;
            if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
              setActive(activeIndex + (dx < 0 ? 1 : -1));
              tick();
            }
          },
          { passive: true }
        );

        setActive(0);
        /* Kick off first auto-advance immediately after init, not after a full interval */
        tick();
      })();
    </script>
  </section>
)}
