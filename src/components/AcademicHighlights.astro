---
/* Academic Highlights — clean, premium cards.
   8 items, premium card design.
   CMS-ready via SCHOOL.academicHighlights. */
import {
  BookOpen,
  BookOpenCheck,
  Mic,
  Trophy,
  Award,
  Users,
  GraduationCap,
  Atom,
  HeartHandshake,
} from "lucide-astro";
import { SCHOOL } from "../data/school";

const { academicHighlights: ah } = SCHOOL;

const iconMap: Record<string, any> = {
  BookOpen,
  BookOpenCheck,
  Mic,
  Trophy,
  Award,
  Users,
  GraduationCap,
  Atom,
  HeartHandshake,
};

const groupedHighlights = ah.groups.map((group) => ({
  ...group,
  items: group.itemIds.flatMap((itemId) => {
    const item = ah.items.find((entry) => entry.id === itemId);
    return item ? [item] : [];
  }),
}));
---

{ah.enabled && (
  <section id="academic-highlights" class="relative py-14 sm:py-16 lg:py-20 bg-white overflow-hidden">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div data-reveal="fade" class="text-center max-w-2xl mx-auto mb-8 lg:mb-12">
        <h2 data-reveal class="text-3xl sm:text-4xl lg:text-[2.85rem] font-bold font-serif text-charcoal leading-tight tracking-tight mb-4">
          {ah.title}
        </h2>
        <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed max-w-[42rem] mx-auto">
          {ah.subtitle}
        </p>
      </div>

      <div data-reveal-group class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
        {groupedHighlights.map((group) => (
          <section class="rounded-2xl border border-ivory-dark bg-white overflow-hidden w-full">
            <div class="px-4 sm:px-5 py-3 border-b border-ivory-dark bg-ivory/55">
              <h3 class="text-lg font-bold font-serif text-charcoal">{group.title}</h3>
            </div>

            <div class="divide-y divide-ivory-dark">
              {group.items.map((item) => {
                const Icon = iconMap[item.icon] || BookOpen;
                const isHighlight = Boolean(item.highlight);
                return (
                  <article class="flex items-start gap-3 px-4 sm:px-5 py-3.5">
                    <div class={`mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md ${isHighlight ? "bg-brand-red/10" : "bg-deep-green/10"}`}>
                      <Icon class={`w-4 h-4 ${isHighlight ? "text-brand-red" : "text-deep-green"}`} aria-hidden="true" />
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-center gap-2 mb-1.5">
                        <h4 class="text-base font-bold font-serif text-charcoal leading-snug">
                          {item.title}
                        </h4>
                        {isHighlight && (
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full border border-brand-red/20 bg-brand-red/5 text-brand-red text-[10px] font-bold uppercase tracking-wider">
                            <span class="w-1 h-1 rounded-full bg-brand-red" aria-hidden="true"></span>
                            Result
                          </span>
                        )}
                      </div>
                      <p class="text-slate text-sm leading-relaxed">
                        {item.description}
                      </p>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>
)}

<style>
</style>
