---
/* Principal's Message — premium full-width message card.
   No fake portrait or signature. Author label is the school
   leadership unless a real name is provided via CMS later. */
import { Quote } from "lucide-astro";
import { SCHOOL } from "../data/school";

const { principalMessage: pm } = SCHOOL;
---

{pm.enabled && (
  <section id="principal-message" class="relative py-16 lg:py-24 bg-deep-green/[0.03] overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-[radial-gradient(#0D5E3E_0.7px,transparent_0.7px)] [background-size:28px_28px] opacity-[0.04]"></div>
    </div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div data-reveal="fade" class="text-center max-w-2xl mx-auto mb-10 lg:mb-14">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
          {pm.eyebrow}
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-serif text-charcoal leading-tight tracking-tight">
          {pm.title}
        </h2>
      </div>

      <!-- Premium message card — left green accent border, full-width text -->
      <article
        data-reveal="slide-up"
        class="relative bg-white rounded-3xl border border-ivory-dark shadow-lg shadow-charcoal/[0.05] overflow-hidden"
      >
        <!-- Green left accent border -->
        <div class="absolute top-0 left-0 bottom-0 w-1.5 bg-gradient-to-b from-deep-green-light via-deep-green to-deep-green-dark" aria-hidden="true"></div>

        <div class="relative p-7 sm:p-10 lg:p-14 pl-8 sm:pl-12 lg:pl-16">
          <!-- Quote icon -->
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-deep-green/10 mb-6">
            <Quote class="w-6 h-6 text-deep-green" aria-hidden="true" />
          </div>

          <!-- Message body — clean paragraphs, not oversized -->
          <div class="space-y-5 sm:space-y-6 max-w-3xl">
            {pm.body.map((paragraph) => (
              <p class="text-charcoal text-base sm:text-lg leading-relaxed">
                {paragraph}
              </p>
            ))}
          </div>

          <!-- Value chips — small, informational, not pushy -->
          {pm.valueChips && pm.valueChips.length > 0 && (
            <ul class="flex flex-wrap gap-2 mt-8" role="list">
              {pm.valueChips.map((chip) => (
                <li class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-deep-green/[0.06] text-deep-green text-xs sm:text-sm font-semibold rounded-full">
                  <span class="w-1 h-1 rounded-full bg-deep-green" aria-hidden="true"></span>
                  {chip}
                </li>
              ))}
            </ul>
          )}

          <!-- Author label — footer with thin divider -->
          <footer class="mt-8 pt-6 border-t border-ivory-dark">
            <p class="text-sm font-semibold text-charcoal">
              {pm.authorLabel}
            </p>
            <p class="text-xs text-slate-light mt-0.5">
              Al-Falah High School, Adilabad
            </p>
          </footer>
        </div>
      </article>
    </div>
  </section>
)}
