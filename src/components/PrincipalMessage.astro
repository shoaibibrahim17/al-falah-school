---
import { Quote, User } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<section class="relative py-16 lg:py-28 bg-white overflow-hidden">
  <!-- Decorative backdrop -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[42rem] h-[42rem] rounded-full blur-3xl"
      style="background: radial-gradient(circle, color-mix(in srgb, var(--color-gold) 4%, transparent), transparent 70%);"
    ></div>
    <!-- Oversize background quote glyph -->
    <span class="absolute top-4 left-1/2 -translate-x-1/2 text-[18rem] sm:text-[24rem] font-serif font-bold text-deep-green/[0.025] leading-none select-none">"</span>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <!-- Subtle ornament: line + quote icon + line -->
      <div data-reveal="fade" class="flex items-center justify-center gap-3 mb-6 sm:mb-8">
        <div class="h-px w-12 bg-gradient-to-r from-transparent to-gold/40"></div>
        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-gold to-gold-light flex items-center justify-center shadow-lg shadow-gold/25">
          <Quote class="w-5 h-5 text-white" />
        </div>
        <div class="h-px w-12 bg-gradient-to-l from-transparent to-gold/40"></div>
      </div>

      <blockquote
        data-reveal-words
        class="text-xl sm:text-2xl lg:text-[1.75rem] font-serif font-medium text-charcoal leading-[1.5] mb-10 text-balance"
      >
        {SCHOOL.principal.message}
      </blockquote>

      <div data-reveal class="flex items-center justify-center gap-4">
        <div class="relative w-16 h-16 rounded-full flex items-center justify-center" aria-hidden="true">
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-deep-green to-deep-green-light"></div>
          <div class="absolute inset-[2px] rounded-full bg-white flex items-center justify-center">
            <User class="w-7 h-7 text-deep-green" />
          </div>
        </div>
        <div class="text-left">
          <cite class="not-italic">
            <div class="font-bold font-serif text-lg text-charcoal">{SCHOOL.principal.name}</div>
            <div class="text-slate text-sm flex items-center gap-1.5 mt-0.5">
              <span class="w-1 h-1 rounded-full bg-gold"></span>
              {SCHOOL.principal.role}
            </div>
          </cite>
        </div>
      </div>
    </div>
  </div>
</section>
