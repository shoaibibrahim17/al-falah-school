---
/* Principal's Message — editorial school leadership section.
   Left: compact values rail.
   Right: message text + author label.
   No fake portrait or signature. */
import { Sparkles, Shield, Heart, Users, BookOpen, GraduationCap, Compass } from "lucide-astro";
import { SCHOOL } from "../data/school";

const { principalMessage: pm } = SCHOOL;

const iconMap: Record<string, any> = {
  Sparkles, Shield, Heart, Users, BookOpen, GraduationCap, Compass,
};
---

{pm.enabled && (
  <section id="principal-message" class="relative py-14 sm:py-16 lg:py-20 bg-white overflow-hidden">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div data-reveal="fade" class="text-center max-w-2xl mx-auto mb-8 lg:mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
          {pm.eyebrow}
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-[2.85rem] font-bold font-serif text-charcoal leading-tight tracking-tight mb-3">
          {pm.title}
        </h2>
        {pm.subtitle && (
          <p class="text-slate text-base sm:text-lg leading-relaxed mb-3 max-w-[42rem] mx-auto">
            {pm.subtitle}
          </p>
        )}
        {pm.animatedLine && (
          <p class="typewriter-line text-deep-green text-sm sm:text-base font-semibold tracking-wide" aria-label={pm.animatedLine}>
            <span class="typewriter-text" data-text={pm.animatedLine}></span><span class="typewriter-cursor" aria-hidden="true">|</span>
          </p>
        )}
      </div>

      <article data-reveal="slide-up" class="relative grid items-start grid-cols-1 sm:grid-cols-[minmax(8.5rem,0.72fr)_minmax(0,1.28fr)] lg:grid-cols-[minmax(12rem,0.72fr)_minmax(0,1.28fr)] gap-0 bg-white border border-ivory-dark rounded-2xl overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-deep-green-light via-deep-green to-deep-green-dark" aria-hidden="true"></div>

        <aside class="border-b sm:border-b-0 sm:border-r border-ivory-dark bg-ivory/50 px-3 py-3.5 sm:px-4 sm:py-5 lg:px-6 lg:py-6">
          <div class="max-w-sm">
            <h3 class="text-[0.88rem] sm:text-lg font-bold font-serif text-charcoal leading-snug mb-1.5">
              {pm.valuesHeading}
            </h3>
            <p class="text-slate text-[0.66rem] sm:text-sm leading-relaxed mb-2 sm:mb-4">
              {pm.valuesDescription}
            </p>
            {/* Mobile: 2-col compact grid. sm+: 1-col stacked list. */}
            <ul class="grid grid-cols-2 gap-1.5 sm:flex sm:flex-col sm:space-y-2" role="list">
              {pm.valueCards.map((card) => {
                const Icon = iconMap[card.icon] || Sparkles;
                return (
                  <li class="flex items-center gap-1.5 rounded-lg border border-ivory-dark bg-white px-2 py-1.5 sm:px-3 sm:py-2">
                    <div class="flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-deep-green/10">
                      <Icon class="w-3 h-3 text-deep-green" aria-hidden="true" />
                    </div>
                    <span class="text-[0.68rem] sm:text-sm font-semibold text-charcoal leading-tight">
                      {card.label}
                    </span>
                  </li>
                );
              })}
            </ul>
          </div>
        </aside>

        <div class="relative p-3.5 sm:p-5 lg:p-8 bg-white">
          <div class="relative max-w-2xl">
            <div class="space-y-3 sm:space-y-5">
              {pm.body.map((paragraph, i) => (
                <p class={`text-charcoal text-[0.9rem] sm:text-[1.02rem] leading-relaxed ${i === 0 ? 'first-paragraph' : ''}`}>
                  {paragraph}
                </p>
              ))}
            </div>

            <footer class="mt-4 pt-3.5 border-t border-ivory-dark flex items-center gap-2.5">
              <div class="w-7 h-7 rounded-full bg-deep-green/10 flex items-center justify-center shrink-0">
                <span class="text-deep-green font-serif font-bold text-[0.8rem]">A</span>
              </div>
              <div>
                <p class="text-[0.84rem] font-bold text-charcoal">{pm.authorLabel}</p>
                <p class="text-xs text-slate-light mt-0.5">{pm.authorLocation}</p>
              </div>
            </footer>
          </div>
        </div>
      </article>
    </div>
  </section>
)}

<script>
  /* Subtle typewriter animation for one line.
     Respects prefers-reduced-motion (renders static text). */
  (() => {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const elements = document.querySelectorAll<HTMLElement>(".typewriter-text");
    elements.forEach((el) => {
      const text = el.dataset.text || el.textContent || "";
      if (prefersReducedMotion) {
        /* Static text, no animation */
        el.textContent = text;
        const cursor = el.parentElement?.querySelector<HTMLElement>(".typewriter-cursor");
        if (cursor) cursor.style.display = "none";
        return;
      }

      /* Typewriter — only run once when the element is in view */
      el.textContent = "";
      const cursor = el.parentElement?.querySelector<HTMLElement>(".typewriter-cursor");
      if (cursor) cursor.style.opacity = "1";

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              let i = 0;
              const speed = 38; /* ms per character — slow, premium */
              const tick = () => {
                if (i <= text.length) {
                  el.textContent = text.slice(0, i);
                  i++;
                  setTimeout(tick, speed);
                } else if (cursor) {
                  /* Fade cursor out after typing completes */
                  setTimeout(() => { cursor.style.opacity = "0"; }, 1200);
                }
              };
              tick();
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.6 }
      );
      observer.observe(el);
    });
  })();
</script>

<style>
  /* Typewriter line container */
  .typewriter-line {
    min-height: 1.5rem; /* Reserve space to prevent layout shift */
    display: inline-flex;
    align-items: center;
    gap: 0;
  }
  .typewriter-text {
    /* Width locked to longest content line to prevent reflow during typing */
    display: inline-block;
  }
  .typewriter-cursor {
    display: inline-block;
    margin-left: 1px;
    font-weight: 300;
    color: currentColor;
    opacity: 0;
    transition: opacity 400ms ease;
    animation: cursor-blink 1.05s ease-in-out infinite;
  }
  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.3; }
  }
  @media (prefers-reduced-motion: reduce) {
    .typewriter-cursor {
      animation: none;
      display: none;
    }
  }

  /* First paragraph gets subtle emphasis on the opening words */
  .first-paragraph::first-letter {
    font-weight: 600;
    color: var(--color-deep-green);
  }
</style>
