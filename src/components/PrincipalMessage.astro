---
/* Principal's Message — minimal and focused on words under quotation. */
import { SCHOOL } from "../data/school";

const { principalMessage: pm } = SCHOOL;
---

{pm.enabled && (
  <section id="principal-message" class="relative py-16 sm:py-20 bg-ivory/30 overflow-hidden">
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6">
      
      <div data-reveal="fade" class="text-center mb-10">
        <h2 class="text-3xl sm:text-4xl font-bold font-serif text-charcoal tracking-tight">
          {pm.title}
        </h2>
      </div>

      <div data-reveal="slide-up" class="relative max-w-2xl mx-auto text-center">
        <!-- Minimal decorative quotes -->
        <div class="text-deep-green/20 font-serif text-8xl leading-none h-12 flex justify-center mb-4" aria-hidden="true">
          “
        </div>

        <blockquote class="space-y-6 mb-8 relative z-10">
          {pm.body.map((quote) => (
            <p class="text-charcoal text-lg sm:text-xl font-serif italic leading-relaxed">
              {quote}
            </p>
          ))}
        </blockquote>
        
        <div class="flex items-center justify-center gap-3 mt-6 pt-6 border-t border-ivory-dark w-max mx-auto px-8">
          <div class="w-8 h-8 rounded-full bg-deep-green text-white flex items-center justify-center font-serif text-sm font-bold">
            P
          </div>
          <div class="text-left">
            <cite class="not-italic text-sm font-bold text-charcoal block">{pm.authorLabel}</cite>
          </div>
        </div>
      </div>

    </div>
  </section>
)}
