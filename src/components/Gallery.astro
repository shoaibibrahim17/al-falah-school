---
import { Star, BookOpen, GraduationCap, X, ChevronLeft, ChevronRight, Image as ImageIcon } from "lucide-astro";
import { SCHOOL } from "../data/school";
import { assetUrl } from "../utils/assetUrl";

const categoryIcons: Record<string, typeof Star> = {
  activities: Star,
  classrooms: BookOpen,
  events: GraduationCap,
};

const albums = SCHOOL.gallery.categories.filter((cat) => cat.images.length > 0);

/* Pre-compute base URL for client-side use */
const BASE_URL = (import.meta.env?.BASE_URL ?? "/").replace(/\/$/, "");
const baseUrl = BASE_URL ? `${BASE_URL}/` : "/";

/* Server-side album data with base URL pre-applied */
const albumDataScript = `window.__ALBUM_DATA__ = ${JSON.stringify(
  Object.fromEntries(
    albums.map((album) => [
      album.id,
      {
        name: album.name,
        subtitle: album.subtitle,
        coverImage: baseUrl + album.coverImage.replace(/^\//, ""),
        images: album.images.map((img) => ({
          src: baseUrl + img.src.replace(/^\//, ""),
          alt: img.alt,
          caption: img.caption ?? "",
          type: img.type ?? "image",
        })),
      },
    ])
  )
)};`;
---

<section id="gallery" class="relative py-16 lg:py-24 bg-white overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-10 lg:mb-14">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
        Campus Life
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        Our <span class="text-gradient-green">Gallery</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.gallery.subtitle}
      </p>
    </div>

    <!-- Album cards grid -->
    {albums.length > 0 ? (
      <div data-reveal-group class="album-grid">
        {albums.map((album) => {
          const Icon = categoryIcons[album.id] ?? ImageIcon;
          return (
            <button
              type="button"
              class="album-card"
              data-album-id={album.id}
              aria-label={`Open ${album.name} album — ${album.images.length} photos`}
            >
              <!-- Cover image -->
              <div class="album-cover">
                <img
                  src={assetUrl(album.coverImage)}
                  alt={`${album.name} cover`}
                  class="album-cover-img"
                  loading="lazy"
                  decoding="async"
                />
                <!-- Gradient overlay -->
                <div class="album-cover-overlay" aria-hidden="true"></div>
                <!-- Icon + count badge -->
                <div class="album-cover-badge" aria-hidden="true">
                  <Icon class="w-4 h-4" />
                  <span>{album.images.length}</span>
                </div>
              </div>
              <!-- Album info -->
              <div class="album-info">
                <h3 class="album-title">{album.name}</h3>
                <p class="album-subtitle">{album.images.length} photos</p>
              </div>
            </button>
          );
        })}
      </div>
    ) : (
      <p class="text-center text-slate text-sm">Gallery photos will be added soon.</p>
    )}

  </div>
</section>

<!-- ── Album Modal ── -->
<div
  id="album-modal"
  class="album-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Photo album viewer"
  hidden
>
  <!-- Backdrop -->
  <div class="album-backdrop" data-album-close></div>

  <!-- Modal panel -->
  <div class="album-panel">
    <!-- Header -->
    <div class="album-header">
      <div class="album-header-left">
        <span class="album-header-icon" id="album-modal-icon"></span>
        <div>
          <h2 class="album-header-title" id="album-modal-title"></h2>
          <p class="album-header-count" id="album-modal-count"></p>
        </div>
      </div>
      <button
        type="button"
        class="album-close-btn"
        data-album-close
        aria-label="Close album"
      >
        <X class="w-5 h-5" />
      </button>
    </div>

    <!-- Image grid -->
    <div class="album-image-grid" id="album-image-grid" role="list"></div>
  </div>
</div>

<!-- ── Image Lightbox ── -->
<div
  id="image-lightbox"
  class="img-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Photo preview"
  hidden
>
  <div class="img-lightbox-backdrop" data-img-close></div>
  <div class="img-lightbox-content">
    <button
      type="button"
      class="img-lightbox-close"
      data-img-close
      aria-label="Close photo"
    >
      <X class="w-5 h-5" />
    </button>
    <button
      type="button"
      class="img-lightbox-prev"
      data-img-prev
      aria-label="Previous photo"
    >
      <ChevronLeft class="w-6 h-6" />
    </button>
    <img id="img-lightbox-img" src="" alt="" class="img-lightbox-img" />
    <video id="img-lightbox-video" class="img-lightbox-video" controls playsinline></video>
    <p id="img-lightbox-caption" class="img-lightbox-caption"></p>
    <button
      type="button"
      class="img-lightbox-next"
      data-img-next
      aria-label="Next photo"
    >
      <ChevronRight class="w-6 h-6" />
    </button>
  </div>
</div>

<script>
  (() => {
    /* ── Album cards → open modal ── */
    const albumCards = document.querySelectorAll<HTMLButtonElement>("[data-album-id]");
    const modal = document.getElementById("album-modal");
    const modalTitle = document.getElementById("album-modal-title");
    const modalCount = document.getElementById("album-modal-count");
    const modalIcon = document.getElementById("album-modal-icon");
    const imageGrid = document.getElementById("album-image-grid");

    const iconMap: Record<string, string> = {
      activities: "★",
      classrooms: "📘",
      events: "🎓",
    };

    albumCards.forEach((card) => {
      card.addEventListener("click", () => {
        const albumId = card.dataset.albumId;
        if (!albumId || !modal) return;

        const albumData = (window as any).__ALBUM_DATA__?.[albumId];
        if (!albumData) return;

        /* Populate modal header */
        if (modalTitle) modalTitle.textContent = albumData.name;
        if (modalCount) modalCount.textContent = `${albumData.images.length} photos`;
        if (modalIcon) modalIcon.textContent = iconMap[albumId] ?? "📷";

        /* Build image grid — clean thumbnails, no per-image labels */
        if (imageGrid) {
          imageGrid.innerHTML = "";
          albumData.images.forEach((img: { src: string; alt: string; caption: string; type: string }, idx: number) => {
            const isVideo = img.type === "video";
            const item = document.createElement("div");
            item.className = `album-img-item${isVideo ? " is-video" : ""}`;
            item.setAttribute("role", "listitem");
            item.setAttribute("data-img-idx", String(idx));
            item.setAttribute("data-img-caption", img.caption || "");
            item.setAttribute("data-img-type", img.type || "image");

            if (isVideo) {
              /* Video thumbnail — show first frame of video as poster */
              item.innerHTML = `
                <button type="button" class="album-img-btn" aria-label="Play video ${idx + 1}">
                  <video
                    src="${img.src}"
                    class="album-img-thumb"
                    muted
                    preload="metadata"
                  ></video>
                  <div class="album-video-play-btn" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </button>
              `;
            } else {
              item.innerHTML = `
                <button type="button" class="album-img-btn" aria-label="View photo ${idx + 1}">
                  <img
                    src="${img.src}"
                    alt="${img.alt}"
                    class="album-img-thumb"
                    loading="lazy"
                    decoding="async"
                  />
                </button>
              `;
            }
            imageGrid.appendChild(item);
          });
        }

        /* Show modal */
        modal.hidden = false;
        modal.classList.add("is-open");
        document.body.style.overflow = "hidden";
        modal.querySelector<HTMLElement>(".album-close-btn")?.focus();
      });
    });

    /* ── Close album modal ── */
    const closeAlbumModal = () => {
      if (!modal) return;
      modal.hidden = true;
      modal.classList.remove("is-open");
      document.body.style.overflow = "";
    };

    modal?.querySelectorAll("[data-album-close]").forEach((el) => {
      el.addEventListener("click", closeAlbumModal);
    });

    modal?.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Escape") closeAlbumModal();
    });

    /* ── Image lightbox ── */
    const lightbox = document.getElementById("image-lightbox");
    const lightboxImg = document.getElementById("img-lightbox-img") as HTMLImageElement | null;
    const lightboxCaption = document.getElementById("img-lightbox-caption");
    const lightboxVideo = document.getElementById("img-lightbox-video") as HTMLVideoElement | null;
    const prevBtn = document.querySelector<HTMLButtonElement>("[data-img-prev]");
    const nextBtn = document.querySelector<HTMLButtonElement>("[data-img-next]");

    let currentImages: Array<{ src: string; alt: string; caption: string; type: string }> = [];
    let currentIdx = 0;

    const openLightbox = (idx: number) => {
      if (!lightbox || !lightboxImg) return;
      currentIdx = idx;
      const item = currentImages[idx];
      const isVideo = item.type === "video";

      if (isVideo && lightboxVideo) {
        /* Show video player */
        lightboxVideo.src = item.src;
        lightboxVideo.alt = item.alt;
        lightboxVideo.classList.add("is-visible");
        lightboxImg.classList.remove("is-visible");
      } else if (lightboxImg) {
        /* Show image */
        lightboxImg.src = item.src;
        lightboxImg.alt = item.alt;
        lightboxImg.classList.add("is-visible");
        if (lightboxVideo) lightboxVideo.classList.remove("is-visible");
        if (lightboxVideo) lightboxVideo.pause();
      }

      /* Show caption only when meaningful */
      const cap = item.caption;
      if (lightboxCaption) {
        lightboxCaption.textContent = cap && cap.trim().length > 0 ? cap : "";
        lightboxCaption.style.display = cap && cap.trim().length > 0 ? "block" : "none";
      }

      lightbox.hidden = false;
      lightbox.classList.add("is-open");
      document.body.style.overflow = "hidden";
      lightbox.querySelector<HTMLButtonElement>(".img-lightbox-close")?.focus();
      /* Hide prev/next nav when on a video (simple approach) */
      updateLightboxNav();
    };

    const closeLightbox = () => {
      if (!lightbox) return;
      lightbox.hidden = true;
      lightbox.classList.remove("is-open");
      document.body.style.overflow = "";
      /* Pause video when closing */
      if (lightboxVideo) lightboxVideo.pause();
    };

    const updateLightboxNav = () => {
      if (prevBtn) prevBtn.style.display = currentIdx > 0 ? "flex" : "none";
      if (nextBtn) nextBtn.style.display = currentIdx < currentImages.length - 1 ? "flex" : "none";
    };

    /* Attach lightbox triggers to thumbnail buttons */
    const attachLightboxTriggers = () => {
      document.querySelectorAll<HTMLButtonElement>(".album-img-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          const item = btn.closest<HTMLElement>("[data-img-idx]");
          if (!item) return;
          const idx = Number(item.dataset.imgIdx);

          /* Gather all images + captions + type from current album grid */
          const grid = document.getElementById("album-image-grid");
          if (!grid) return;
          const items = Array.from(grid.querySelectorAll<HTMLElement>("[data-img-idx]"));
          currentImages = items.map((el) => {
            const img = el.querySelector("img, video");
            const caption = el.dataset.imgCaption ?? "";
            const type = el.dataset.imgType ?? "image";
            return { src: img?.src ?? "", alt: img?.alt ?? "", caption, type };
          });

          openLightbox(idx);
        });
      });
    };

    /* Re-attach after modal opens (since grid is rebuilt each time) */
    const observer = new MutationObserver(() => {
      attachLightboxTriggers();
    });
    if (imageGrid && modal) {
      observer.observe(imageGrid, { childList: true });
    }

    /* Close lightbox handlers */
    lightbox?.querySelectorAll("[data-img-close]").forEach((el) => {
      el.addEventListener("click", closeLightbox);
    });

    lightbox?.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowRight") navigateLightbox(1);
      if (e.key === "ArrowLeft") navigateLightbox(-1);
    });

    const navigateLightbox = (dir: 1 | -1) => {
      const next = currentIdx + dir;
      if (next < 0 || next >= currentImages.length) return;
      currentIdx = next;
      if (lightboxImg) {
        lightboxImg.src = currentImages[currentIdx].src;
        lightboxImg.alt = currentImages[currentIdx].alt;
      }
      updateLightboxNav();
    };

    prevBtn?.addEventListener("click", () => navigateLightbox(-1));
    nextBtn?.addEventListener("click", () => navigateLightbox(1));
  })();
</script>

<!-- Inject album data for JS (pre-rendered JSON with base URL applied server-side) -->
<script is:inline set:html={albumDataScript}></script>

<style>
  /* ── Album Cards Grid ── */
  .album-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1rem;
  }
  @media (min-width: 480px) {
    .album-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 768px) {
    .album-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }

  .album-card {
    display: flex;
    flex-direction: column;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(30, 41, 59, 0.08);
    border: 1px solid var(--color-ivory-dark, #e8e0d0);
    transition: transform 300ms var(--ease-ios-out),
                box-shadow 300ms var(--ease-ios-out);
  }
  .album-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(30, 41, 59, 0.14);
  }
  .album-card:focus-visible {
    outline: 2px solid var(--color-deep-green, #1a5a3a);
    outline-offset: 2px;
  }

  /* Cover image */
  .album-cover {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-ivory, #faf8f4);
  }
  .album-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-ios-out);
  }
  .album-card:hover .album-cover-img {
    transform: scale(1.05);
  }
  .album-cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(10, 30, 20, 0.45) 100%
    );
  }
  .album-cover-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.6rem;
    background: rgba(10, 30, 20, 0.65);
    backdrop-filter: blur(6px);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    border-radius: 9999px;
    letter-spacing: 0.02em;
  }

  /* Album info */
  .album-info {
    padding: 0.875rem 1rem 1rem;
    background: var(--color-white, #fff);
  }
  .album-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-charcoal, #1c1917);
    margin: 0 0 0.2rem;
  }
  .album-subtitle {
    font-size: 0.75rem;
    color: var(--color-slate, #64748b);
    margin: 0;
  }

  /* ── Album Modal ── */
  .album-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: stretch;
  }
  .album-modal[hidden] {
    display: none;
  }
  .album-modal:not(.is-open) {
    opacity: 0;
    pointer-events: none;
  }
  .album-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .album-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 15, 20, 0.7);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .album-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 900px;
    margin: auto;
    max-height: 90vh;
    background: var(--color-white, #fff);
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(10, 20, 15, 0.3);
  }
  @media (max-width: 639px) {
    .album-panel {
      max-height: 100vh;
      border-radius: 1rem 1rem 0 0;
      margin-top: auto;
    }
    .album-modal {
      align-items: flex-end;
    }
  }

  /* Modal header */
  .album-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-ivory-dark, #e8e0d0);
    flex-shrink: 0;
  }
  .album-header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .album-header-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.625rem;
    background: var(--color-deep-green, #1a5a3a);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .album-header-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-charcoal, #1c1917);
    margin: 0;
  }
  .album-header-count {
    font-size: 0.75rem;
    color: var(--color-slate, #64748b);
    margin: 0;
  }
  .album-close-btn {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    border: 1.5px solid var(--color-ivory-dark, #e8e0d0);
    background: transparent;
    color: var(--color-slate, #64748b);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 200ms, color 200ms;
    flex-shrink: 0;
  }
  .album-close-btn:hover {
    background: var(--color-deep-green, #1a5a3a);
    color: white;
    border-color: var(--color-deep-green, #1a5a3a);
  }

  /* Modal image grid */
  .album-image-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    padding: 1rem 1.25rem 1.25rem;
    overflow-y: auto;
    flex: 1;
  }
  @media (min-width: 640px) {
    .album-image-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 0.625rem;
      padding: 1.25rem;
    }
  }

  .album-img-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 0.625rem;
    overflow: hidden;
    background: var(--color-ivory, #faf8f4);
  }
  .album-img-btn {
    position: absolute;
    inset: 0;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .album-img-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease-ios-out);
    display: block;
  }
  .album-img-btn:hover .album-img-thumb {
    transform: scale(1.06);
  }

  /* Video thumbnail play button */
  .album-video-play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 30, 20, 0.45);
    color: white;
    transition: background 200ms;
  }
  .album-video-play-btn svg {
    width: 2rem;
    height: 2rem;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.4));
  }
  .album-img-btn:hover .album-video-play-btn {
    background: rgba(10, 30, 20, 0.55);
  }

  /* Video items in grid get a border accent */
  .album-img-item.is-video {
    border: 2px solid rgba(26, 90, 58, 0.25);
  }

  /* ── Image Lightbox ── */
  .img-lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .img-lightbox[hidden] {
    display: none;
  }
  .img-lightbox:not(.is-open) {
    opacity: 0;
    pointer-events: none;
  }
  .img-lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .img-lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 10, 8, 0.92);
    cursor: pointer;
  }
  .img-lightbox-content {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 90vw;
    max-height: 90vh;
    z-index: 1;
  }
  .img-lightbox-img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 0.5rem;
    flex: 1;
  }
  .img-lightbox-img { display: block; }
  .img-lightbox-img:not(.is-visible) { display: none; }
  .img-lightbox-video {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 0.5rem;
    flex: 1;
    display: none;
  }
  .img-lightbox-video.is-visible { display: block; }
  .img-lightbox-caption {
    position: absolute;
    bottom: -2rem;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.70);
    display: none;
  }
  .img-lightbox-close {
    position: absolute;
    top: -2.75rem;
    right: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 200ms;
  }
  .img-lightbox-close:hover {
    background: rgba(255, 255, 255, 0.25);
  }
  .img-lightbox-prev,
  .img-lightbox-next {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 200ms;
  }
  .img-lightbox-prev:hover,
  .img-lightbox-next:hover {
    background: rgba(255, 255, 255, 0.25);
  }
  .img-lightbox-prev {
    display: none;
  }
  .img-lightbox-next {
