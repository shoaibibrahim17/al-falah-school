---
import { MapPin, ScrollText, Library, Trophy, Music, FlaskConical } from "lucide-astro";
import { SCHOOL } from "../data/school";

/* Bento tile config — gradient palette + icon per topic, all decorative.
   Tiles laid out on a 4-col × 3-row grid on lg+. Falls back to 2-col on sm,
   single column on mobile. */
const tileConfig = [
  { gradient: "from-deep-green via-deep-green-dark to-charcoal", iconBg: "bg-white", iconColor: "text-deep-green", Icon: MapPin, span: "lg:col-span-2 lg:row-span-2", aspect: "aspect-[4/5] lg:aspect-auto" },
  { gradient: "from-charcoal via-charcoal to-deep-green-dark", iconBg: "bg-white/90", iconColor: "text-deep-green", Icon: ScrollText, span: "lg:col-span-2", aspect: "aspect-[16/9] lg:aspect-auto" },
  { gradient: "from-deep-green-light via-deep-green to-deep-green-dark", iconBg: "bg-white", iconColor: "text-deep-green", Icon: Library, span: "", aspect: "aspect-square" },
  { gradient: "from-deep-green-dark via-deep-green to-deep-green-light", iconBg: "bg-white", iconColor: "text-deep-green", Icon: Trophy, span: "", aspect: "aspect-square" },
  { gradient: "from-deep-green-dark via-deep-green to-deep-green-light", iconBg: "bg-white", iconColor: "text-deep-green", Icon: Music, span: "lg:col-span-2", aspect: "aspect-[16/9] lg:aspect-auto" },
  { gradient: "from-slate via-charcoal to-deep-green-dark", iconBg: "bg-white", iconColor: "text-deep-green", Icon: FlaskConical, span: "lg:col-span-2", aspect: "aspect-[16/9] lg:aspect-auto" },
];
---

<section id="gallery" class="relative py-16 lg:py-28 bg-white overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
        Campus Life
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        Glimpses of <span class="text-gradient-green">Al-Falah</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.gallery.subtitle}
      </p>
    </div>

    <div data-reveal-group class="grid grid-cols-2 lg:grid-cols-4 lg:grid-rows-3 auto-rows-fr gap-3 sm:gap-4 lg:gap-5">
      {SCHOOL.gallery.images.map((item, i) => {
        const cfg = tileConfig[i] ?? tileConfig[0];
        const Icon = cfg.Icon;
        const hasImage = Boolean(item.src);

        return (
          <div
            data-gallery-card
            class={`gallery-item relative ${cfg.aspect} ${cfg.span} rounded-2xl overflow-hidden border border-ivory-dark focus-visible:outline-deep-green cursor-pointer group`}
            tabindex="0"
            role="img"
            aria-label={item.alt}
          >
            {hasImage ? (
              /* ── Real photo ── */
              <img
                src={item.src}
                alt={item.alt}
                class="gallery-media absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            ) : (
              /* ── Decorative placeholder (icon tile) ── */
              <div class={`gallery-media bg-gradient-to-br ${cfg.gradient}`}>
                <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.12)_1px,transparent_1px)] [background-size:18px_18px] opacity-50"></div>
                <div class="absolute inset-0 bg-gradient-to-tr from-charcoal/30 via-transparent to-white/10"></div>
                <div class="absolute -top-10 -right-10 w-32 h-32 rounded-full bg-white/15 blur-2xl"></div>
                <div class="absolute -bottom-10 -left-10 w-32 h-32 rounded-full bg-black/20 blur-3xl"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div
                    data-card-inner
                    class={`relative w-16 h-16 sm:w-20 sm:h-20 rounded-2xl ${cfg.iconBg} flex items-center justify-center shadow-xl shadow-charcoal/30 backdrop-blur-sm transition-transform duration-500 ease-out group-hover:scale-110 group-hover:-rotate-3`}
                    style="--inner-delay: 100ms"
                  >
                    <Icon class={`w-8 h-8 sm:w-10 sm:h-10 ${cfg.iconColor}`} />
                  </div>
                </div>
              </div>
            )}

            {/* Always-visible caption strip */}
            <div class="absolute bottom-0 inset-x-0 p-4 sm:p-5 bg-gradient-to-t from-charcoal/85 via-charcoal/40 to-transparent pointer-events-none">
              <p class="text-white text-sm sm:text-base font-semibold tracking-tight">{item.caption}</p>
              <p class="text-white/70 text-xs mt-0.5 line-clamp-1">{item.alt}</p>
            </div>

            {/* Hover scrim */}
            <div class="gallery-hover-overlay absolute inset-0"></div>
          </div>
        );
      })}
    </div>

    {/* Footnote: real photos coming soon — shows only when all images are placeholders */}
    {SCHOOL.gallery.images.every((img) => !img.src) && (
      <p class="text-center text-slate-light text-xs mt-8 italic">
        Photos of our campus and activities will be added soon.
      </p>
    )}
  </div>
</section>