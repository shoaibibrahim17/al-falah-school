---
import { MapPin, BookOpen, Library, Users, GraduationCap, Star } from "lucide-astro";
import { SCHOOL } from "../data/school";

/* Tile config — simple, consistent gradient palette for placeholder tiles.
   Each tile has a distinct gradient so the grid looks intentional
   rather than all the same. */
const tileConfig = [
  { gradient: "from-deep-green via-deep-green-dark to-charcoal", iconBg: "bg-white/10", iconColor: "text-white", Icon: MapPin, label: "Location" },
  { gradient: "from-charcoal via-charcoal to-deep-green-dark", iconBg: "bg-white/10", iconColor: "text-white", Icon: BookOpen, label: "Learning" },
  { gradient: "from-deep-green-dark via-deep-green to-deep-green-light", iconBg: "bg-white/10", iconColor: "text-white", Icon: Library, label: "Study" },
  { gradient: "from-deep-green via-deep-green-light to-deep-green-dark", iconBg: "bg-white/10", iconColor: "text-white", Icon: Users, label: "Community" },
  { gradient: "from-deep-green-dark via-charcoal to-deep-green", iconBg: "bg-white/10", iconColor: "text-white", Icon: GraduationCap, label: "Growth" },
  { gradient: "from-slate via-charcoal to-deep-green-dark", iconBg: "bg-white/10", iconColor: "text-white", Icon: Star, label: "Values" },
];
---

<section id="gallery" class="relative py-16 lg:py-24 bg-white overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-10 lg:mb-14">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
        Campus Life
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        Our <span class="text-gradient-green">School</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.gallery.subtitle}
      </p>
    </div>

    <!-- Gallery grid -->
    <div data-reveal-group class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
      {SCHOOL.gallery.images.map((item, i) => {
        const cfg = tileConfig[i] ?? tileConfig[0];
        const Icon = cfg.Icon;
        const hasImage = Boolean(item.src);

        return (
          <div
            data-gallery-card
            class={`gallery-item relative rounded-xl overflow-hidden border border-ivory-dark focus-visible:outline-deep-green cursor-pointer group aspect-[4/3]`}
            tabindex="0"
            role="img"
            aria-label={item.alt}
          >
            {hasImage ? (
              /* Real photo */
              <img
                src={item.src}
                alt={item.alt}
                class="gallery-media absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            ) : (
              /* Placeholder tile — simple, consistent, not distracting */
              <div class={`gallery-media absolute inset-0 bg-gradient-to-br ${cfg.gradient}`}>
                <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.08)_1px,transparent_1px)] [background-size:20px_20px] opacity-40"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="flex flex-col items-center gap-2">
                    <div class={`w-12 h-12 sm:w-14 sm:h-14 rounded-xl ${cfg.iconBg} backdrop-blur-sm flex items-center justify-center`}>
                      <Icon class={`w-6 h-6 sm:w-7 sm:h-7 ${cfg.iconColor}`} />
                    </div>
                    <span class="text-white/70 text-xs font-medium">{cfg.label}</span>
                  </div>
                </div>
              </div>
            )}

            {/* Caption strip */}
            <div class="absolute bottom-0 inset-x-0 px-4 py-3 bg-gradient-to-t from-charcoal/80 to-transparent">
              <p class="text-white text-sm font-medium">{item.caption}</p>
            </div>

            {/* Hover overlay */}
            <div class="gallery-hover-overlay absolute inset-0"></div>
          </div>
        );
      })}
    </div>

    <!-- Note about photos -->
    {SCHOOL.gallery.images.every((img) => !img.src) && (
      <p class="text-center text-slate-light text-xs mt-6">
        School photos will be added here once available.
      </p>
    )}
  </div>
</section>