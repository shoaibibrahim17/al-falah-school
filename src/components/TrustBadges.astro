---
import { SCHOOL } from "../data/school";
---

<section class="py-10 bg-white border-y border-ivory-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {SCHOOL.trustBadges.map((badge, i) => (
        <div class="text-center animate-fade-in-up" class:list={[`stagger-${i + 1}`]}>
          <div class="text-3xl sm:text-4xl font-bold font-serif text-deep-green mb-1">
            {badge.value}
          </div>
          <div class="text-sm text-slate font-medium">
            {badge.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
