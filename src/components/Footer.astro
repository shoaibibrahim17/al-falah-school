---
import { School, Facebook, Instagram, Youtube, MapPin, Mail, Phone } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<footer class="relative bg-charcoal text-white overflow-hidden">
  <!-- Top gradient accent line -->
  <div class="h-1 bg-gradient-to-r from-deep-green via-gold to-deep-green" aria-hidden="true"></div>

  <!-- Decorative background -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(rgba(201,154,62,0.06)_1px,transparent_1px)] [background-size:24px_24px]"></div>
    <div class="absolute -top-32 right-1/4 w-72 h-72 rounded-full bg-deep-green/20 blur-3xl"></div>
    <div class="absolute -bottom-32 left-1/4 w-72 h-72 rounded-full bg-gold/10 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-14 lg:py-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-gold to-gold-light flex items-center justify-center shadow-lg shadow-gold/25">
            <School class="w-6 h-6 text-charcoal" />
          </div>
          <div>
            <span class="block text-lg font-bold font-serif text-white leading-tight">{SCHOOL.shortName}</span>
            <span class="block text-[10px] text-gold font-medium tracking-[0.18em] uppercase leading-tight mt-0.5">International School</span>
          </div>
        </div>
        <p class="text-white/70 text-sm sm:text-base leading-relaxed max-w-md">
          {SCHOOL.footer.description}
        </p>

        <!-- Inline contact -->
        <div class="mt-6 space-y-2.5">
          <div class="flex items-start gap-2.5 text-white/70 text-sm">
            <MapPin class="w-4 h-4 mt-0.5 text-gold shrink-0" />
            <span>{SCHOOL.location.full}</span>
          </div>
          <a href={`mailto:${SCHOOL.contact.email}`} class="flex items-center gap-2.5 text-white/70 hover:text-gold text-sm no-underline transition-colors duration-200 focus-visible:outline-gold">
            <Mail class="w-4 h-4 text-gold shrink-0" />
            <span>{SCHOOL.contact.email}</span>
          </a>
          <a href={`tel:${SCHOOL.contact.phone}`} class="flex items-center gap-2.5 text-white/70 hover:text-gold text-sm no-underline transition-colors duration-200 focus-visible:outline-gold">
            <Phone class="w-4 h-4 text-gold shrink-0" />
            <span>{SCHOOL.contact.phone}</span>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="text-xs font-bold text-gold uppercase tracking-[0.18em] mb-5">Quick Links</h4>
        <ul class="space-y-3">
          {SCHOOL.footer.quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="group inline-flex items-center gap-2 text-white/70 hover:text-gold text-sm transition-colors duration-200 no-underline focus-visible:outline-gold cursor-pointer"
              >
                <span class="w-1 h-1 rounded-full bg-gold/40 group-hover:bg-gold transition-colors duration-200"></span>
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="text-xs font-bold text-gold uppercase tracking-[0.18em] mb-5">Connect</h4>
        <div class="flex gap-2.5">
          <a
            href={SCHOOL.footer.socialLinks.facebook}
            class="w-10 h-10 rounded-xl bg-white/[0.06] hover:bg-gold hover:text-charcoal flex items-center justify-center transition-all duration-300 focus-visible:outline-gold cursor-pointer border border-white/10 hover:border-gold"
            aria-label="Facebook"
          >
            <Facebook class="w-4 h-4" />
          </a>
          <a
            href={SCHOOL.footer.socialLinks.instagram}
            class="w-10 h-10 rounded-xl bg-white/[0.06] hover:bg-gold hover:text-charcoal flex items-center justify-center transition-all duration-300 focus-visible:outline-gold cursor-pointer border border-white/10 hover:border-gold"
            aria-label="Instagram"
          >
            <Instagram class="w-4 h-4" />
          </a>
          <a
            href={SCHOOL.footer.socialLinks.youtube}
            class="w-10 h-10 rounded-xl bg-white/[0.06] hover:bg-gold hover:text-charcoal flex items-center justify-center transition-all duration-300 focus-visible:outline-gold cursor-pointer border border-white/10 hover:border-gold"
            aria-label="YouTube"
          >
            <Youtube class="w-4 h-4" />
          </a>
        </div>
        <p class="text-white/50 text-xs mt-6 leading-relaxed">
          {SCHOOL.contact.hours}
        </p>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-7 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/50 text-xs text-center sm:text-left">
        {SCHOOL.footer.copyright}
      </p>
      <p class="text-white/40 text-[11px] tracking-wider uppercase">
        Built with care for our community
      </p>
    </div>
  </div>
</footer>
