---
import { MapPin, Mail, Phone, MessageCircle, Youtube } from "lucide-astro";
import { SCHOOL } from "../data/school";

const base = import.meta.env.BASE_URL;
const phones = SCHOOL.contact.phones ?? [];
const socialIcons = {
  youtube: Youtube,
  whatsapp: MessageCircle,
} as const;
const socialLinks = Object.entries(SCHOOL.footer.socialLinks)
  .filter(([, href]) => Boolean(href && href !== "#"))
  .map(([key, href]) => ({
    key,
    href,
    Icon: socialIcons[key as keyof typeof socialIcons],
    label: key[0].toUpperCase() + key.slice(1),
  }));
---

<footer class="relative bg-deep-green-dark text-white">
  <!-- 2px solid green top border — mirrors BrandHeader bottom border -->
  <div class="h-[2px] bg-deep-green" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 sm:pt-14 lg:pt-16 pb-6">

    <!-- ── Main 3-column layout ── -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-12">

      <!-- Column 1: School Identity -->
      <div class="md:col-span-1">
        <!-- Logo row: small white strip, clean, intentional -->
        <a href="#" class="inline-block focus-visible:outline-white rounded-sm mb-5" aria-label={`${SCHOOL.name} home`}>
          <div class="bg-white rounded-md px-3 py-1.5 inline-block">
            <img
              src={`${base}brand/al-falah-header-logo.svg`}
              alt={`${SCHOOL.name} official logo`}
              width="2067"
              height="355"
              decoding="async"
              loading="lazy"
              class="block h-6 w-auto select-none"
            />
          </div>
        </a>

        <h3 class="text-base font-bold font-serif text-white tracking-tight leading-snug">
          {SCHOOL.name}
        </h3>
        <p class="text-xs text-white/65 font-medium tracking-[0.15em] uppercase mt-0.5 mb-4">
          {SCHOOL.footer.identityLine}
        </p>

        <p class="text-sm text-white/75 leading-relaxed max-w-xs">
          {SCHOOL.footer.description}
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div class="md:col-span-1">
        <h4 class="text-[11px] font-bold text-white/90 uppercase tracking-[0.18em] mb-4">
          {SCHOOL.footer.quickLinksTitle}
        </h4>
        <nav aria-label="Footer navigation">
          <ul class="space-y-2">
            {SCHOOL.footer.quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-block text-sm text-white/70 hover:text-white transition-colors duration-200 no-underline focus-visible:outline-white"
                >
                  {link.label}
                </a>
              </li>
            ))}
            {SCHOOL.faculty.enabled && (
              <li>
                <a
                  href="#faculty"
                  class="inline-block text-sm text-white/70 hover:text-white transition-colors duration-200 no-underline focus-visible:outline-white"
                >
                  Faculty
                </a>
              </li>
            )}
          </ul>
        </nav>
      </div>

      <!-- Column 3: Contact & Parent Support -->
      <div class="md:col-span-1">
        <h4 class="text-[11px] font-bold text-white/90 uppercase tracking-[0.18em] mb-4">
          {SCHOOL.footer.parentSupportTitle}
        </h4>
        <ul class="space-y-2 mb-7">
          {SCHOOL.footer.parentSupportLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="inline-block text-sm text-white/70 hover:text-white transition-colors duration-200 no-underline focus-visible:outline-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Social links -->
        {socialLinks.length > 0 && (
          <>
            <h4 class="text-[11px] font-bold text-white/90 uppercase tracking-[0.18em] mb-3">
              {SCHOOL.footer.socialTitle}
            </h4>
            <div class="flex gap-2 mb-7">
              {socialLinks.map(({ key, href, Icon, label }) => (
                <a
                  href={href}
                  class="w-9 h-9 rounded-lg bg-white/[0.08] hover:bg-white text-white/70 hover:text-deep-green flex items-center justify-center transition-all duration-300 focus-visible:outline-white cursor-pointer border border-white/10 hover:border-white"
                  aria-label={label}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon class="w-4 h-4" />
                </a>
              ))}
            </div>
          </>
        )}

        <!-- Contact details (conditional, data-driven) -->
        {(phones.length > 0 || SCHOOL.contact.email || SCHOOL.location.full) && (
          <div class="space-y-2.5">
            {SCHOOL.location.full && (
              <div class="flex items-start gap-2 text-white/70 text-xs">
                <MapPin class="w-3.5 h-3.5 mt-0.5 shrink-0" />
                <span class="leading-relaxed">{SCHOOL.location.full}</span>
              </div>
            )}
            {SCHOOL.contact.email && (
              <a href={`mailto:${SCHOOL.contact.email}`} class="flex items-center gap-2 text-white/70 hover:text-white text-xs no-underline transition-colors duration-200 focus-visible:outline-white">
                <Mail class="w-3.5 h-3.5 shrink-0" />
                <span>{SCHOOL.contact.email}</span>
              </a>
            )}
            {phones.map((phone) => (
              <a href={`tel:${phone.href}`} class="flex items-center gap-2 text-white/70 hover:text-white text-xs no-underline transition-colors duration-200 focus-visible:outline-white">
                <Phone class="w-3.5 h-3.5 shrink-0" />
                <span>{phone.display}</span>
              </a>
            ))}
          </div>
        )}
      </div>

    </div>

    <!-- ── Bottom bar ── -->
    <div class="border-t border-white/10 mt-10 pt-5">
      <p class="text-white/55 text-[11px] text-center">
        {SCHOOL.footer.copyright}
      </p>
    </div>

  </div>
</footer>
