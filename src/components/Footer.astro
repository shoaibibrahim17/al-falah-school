---
import { School, Facebook, Instagram, Youtube } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<footer class="bg-charcoal text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12 lg:py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gold flex items-center justify-center">
            <School class="w-6 h-6 text-charcoal" />
          </div>
          <div>
            <span class="block text-lg font-bold font-serif text-white leading-tight">{SCHOOL.shortName}</span>
            <span class="block text-[10px] text-gold font-medium tracking-wider uppercase leading-tight">International School</span>
          </div>
        </div>
        <p class="text-white/70 text-sm leading-relaxed max-w-md">
          {SCHOOL.footer.description}
        </p>
      </div>

      <div>
        <h4 class="text-sm font-bold text-gold uppercase tracking-wider mb-4">Quick Links</h4>
        <ul class="space-y-2.5">
          {SCHOOL.footer.quickLinks.map((link) => (
            <li>
              <a
                href={`#${link.toLowerCase().replace(/\s+/g, "-")}`}
                class="text-white/70 hover:text-gold text-sm transition-colors duration-200 no-underline focus-visible:outline-gold cursor-pointer"
              >
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-bold text-gold uppercase tracking-wider mb-4">Connect</h4>
        <div class="flex gap-3">
          <a
            href={SCHOOL.footer.socialLinks.facebook}
            class="w-10 h-10 rounded-lg bg-white/10 hover:bg-gold flex items-center justify-center transition-colors duration-200 focus-visible:outline-gold cursor-pointer"
            aria-label="Facebook"
          >
            <Facebook class="w-5 h-5 text-white" />
          </a>
          <a
            href={SCHOOL.footer.socialLinks.instagram}
            class="w-10 h-10 rounded-lg bg-white/10 hover:bg-gold flex items-center justify-center transition-colors duration-200 focus-visible:outline-gold cursor-pointer"
            aria-label="Instagram"
          >
            <Instagram class="w-5 h-5 text-white" />
          </a>
          <a
            href={SCHOOL.footer.socialLinks.youtube}
            class="w-10 h-10 rounded-lg bg-white/10 hover:bg-gold flex items-center justify-center transition-colors duration-200 focus-visible:outline-gold cursor-pointer"
            aria-label="YouTube"
          >
            <Youtube class="w-5 h-5 text-white" />
          </a>
        </div>
        <p class="text-white/50 text-xs mt-4 leading-relaxed">
          {SCHOOL.contact.email}<br />
          {SCHOOL.contact.phone}
        </p>
      </div>
    </div>

    <div class="border-t border-white/10 mt-10 pt-8 text-center">
      <p class="text-white/50 text-xs">
        {SCHOOL.footer.copyright}
      </p>
    </div>
  </div>
</footer>
