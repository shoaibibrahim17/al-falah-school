---
/* School Notice Board — simple max 3 PDF grid */
import { SCHOOL } from "../data/school";
import { FileText, Download } from "lucide-astro";

const { noticeBoard: nb } = SCHOOL;

const activeNotices = (nb.enabled ? nb.notices : [])
  .filter((n) => n.isActive)
  .sort((a, b) => a.order - b.order)
  .slice(0, nb.maxItems);
---

{activeNotices.length > 0 && (
  <section
    id="notices"
    class="relative py-10 sm:py-12 lg:py-14 bg-white"
    aria-labelledby="notice-heading"
  >
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-deep-green via-deep-green-light to-deep-green" aria-hidden="true"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div data-reveal="fade" class="mb-8 sm:mb-10 text-center">
        <h2 id="notice-heading" class="text-2xl sm:text-3xl font-bold font-serif text-charcoal tracking-tight">
          {nb.heading}
        </h2>
        <p class="text-slate text-sm leading-relaxed mt-2 max-w-2xl mx-auto">
          {nb.subtitle}
        </p>
      </div>

      <!-- Notice PDF Grid — Max 3 items -->
      <div data-reveal-group class="flex flex-col sm:grid sm:grid-cols-3 gap-0 sm:gap-6 lg:gap-8" role="list">
        <!-- CMS_LOOP_START:NOTICES -->
        {activeNotices.map((notice, i) => (
          <article
            class="group flex flex-col sm:card-sweep sm:bg-ivory/40 sm:rounded-xl sm:border border-transparent sm:border-ivory-dark transition-all duration-300 sm:hover:border-deep-green/30 sm:hover:bg-ivory/80 sm:hover:shadow-lg sm:hover:shadow-deep-green/5 sm:hover:-translate-y-1 py-5 sm:p-6 border-b border-ivory-dark/60 sm:border-b-0 last:border-b-0"
            role="listitem"
            style={`--order: ${i}`}
          >
            <div class="flex-1 mb-4 sm:mb-6">
              <div class="flex items-center gap-3 mb-3 sm:mb-4">
                <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg bg-deep-green/10 flex items-center justify-center shrink-0">
                  <FileText class="w-4 h-4 sm:w-5 sm:h-5 text-deep-green" />
                </div>
                {notice.pdf?.uploadedDate && (
                  <span class="text-[11px] font-semibold tracking-wider text-slate-light uppercase">
                    {new Date(notice.pdf.uploadedDate).toLocaleDateString("en-IN", {
                      day: "numeric", month: "short", year: "numeric"
                    })}
                  </span>
                )}
              </div>
              
              <h3 class="text-lg font-bold font-serif text-charcoal group-hover:text-deep-green transition-colors duration-200 leading-snug mb-2">
                {notice.title}
              </h3>
              
              {notice.description && (
                <p class="text-slate text-sm leading-relaxed">
                  {notice.description}
                </p>
              )}
            </div>

            {notice.pdf && (
              <a
                href={notice.pdf.file}
                download
                class="inline-flex items-center justify-center gap-2 w-full py-2 sm:py-2.5 bg-deep-green text-white text-[13px] font-bold tracking-wide rounded-lg hover:bg-deep-green-light transition-colors duration-200 focus-visible:outline-deep-green shadow-sm"
                aria-label={`Download ${notice.pdf.label || 'PDF'}`}
              >
                <Download class="w-4 h-4" />
                <span>Download PDF</span>
              </a>
            )}
          </article>
        ))}
        <!-- CMS_LOOP_END:NOTICES -->
      </div>
    </div>
  </section>
)}
