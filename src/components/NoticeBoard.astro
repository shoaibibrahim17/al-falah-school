---
/* School Notice Board — structured rows, official school-office feel.
   Priority-colored left border per row. Red used only for important/urgent.
   Section header shows priority label only when relevant notices exist.
   PDF attachments styled like university notice boards — clean, labelled, dated. */
import { SCHOOL } from "../data/school";
import { FileText, Download } from "lucide-astro";

const { noticeBoard: nb } = SCHOOL;

const now = Date.now();

const activeNotices = (nb.enabled ? nb.notices : [])
  .filter((n) => {
    if (!n.isActive) return false;
    if (n.startDate && Date.parse(n.startDate) > now) return false;
    if (n.endDate && Date.parse(n.endDate) <= now) return false;
    return true;
  })
  .sort((a, b) => a.order - b.order)
  .slice(0, nb.maxItems);

const hasUrgent = activeNotices.some((n) => n.priority === "urgent");
const hasImportant = activeNotices.some((n) => n.priority === "important");
const showPriorityLabel = hasUrgent || hasImportant;

const priorityConfig = {
  normal: {
    border: "border-l-deep-green",
    badgeBg: "bg-deep-green/10",
    badgeText: "text-deep-green",
    label: null,
  },
  important: {
    border: "border-l-brand-red",
    badgeBg: "bg-brand-red/10",
    badgeText: "text-brand-red",
    label: "Important",
  },
  urgent: {
    border: "border-l-brand-red-dark",
    badgeBg: "bg-brand-red-dark/10",
    badgeText: "text-brand-red-dark",
    label: "Urgent",
  },
};

function formatDate(dateStr: string | null): string {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  return d.toLocaleDateString("en-IN", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}
---

{activeNotices.length > 0 && (
  <section
    id="notices"
    class="relative py-10 sm:py-12 lg:py-14 bg-white"
    aria-labelledby="notice-heading"
  >
    <!-- Top green accent line — matches footer/header border identity -->
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-deep-green via-deep-green-light to-deep-green" aria-hidden="true"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Section header — official, compact, practical -->
      <div data-reveal="fade" class="mb-5 sm:mb-7">
        <!-- Priority label — only when relevant notices exist -->
        {showPriorityLabel && (
          <div class="flex items-center gap-2 mb-3">
            <span
              class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded text-[11px] font-bold uppercase tracking-wider ${
                hasUrgent
                  ? "bg-brand-red-dark/10 text-brand-red-dark ring-1 ring-brand-red-dark/20"
                  : "bg-brand-red/10 text-brand-red ring-1 ring-brand-red/20"
              }`}
            >
              {hasUrgent ? "Urgent" : "Important"}
            </span>
            <div class="flex-1 h-px bg-ivory-dark"></div>
          </div>
        )}
        <h2 id="notice-heading" class="text-2xl sm:text-3xl font-bold font-serif text-charcoal tracking-tight">
          {nb.heading}
        </h2>
        <p class="text-slate text-sm leading-relaxed mt-1 max-w-2xl">
          {nb.subtitle}
        </p>
      </div>

      <!-- Notice rows — structured, no decoration -->
      <div class="border-t-2 border-deep-green" role="list">
        {activeNotices.map((notice) => {
          const cfg = priorityConfig[notice.priority] ?? priorityConfig.normal;
          const dateFormatted = formatDate(notice.noticeDate);
          const pdfUploadedFormatted = formatDate(notice.pdf?.uploadedDate ?? null);

          return (
            <article
              data-reveal
            class={`notice-row group relative pl-4 sm:pl-5 pr-3 sm:pr-5 py-4 sm:py-4.5 border-b border-ivory-dark last:border-b-0 ${cfg.border} border-l-[3px] hover:bg-deep-green/[0.012] transition-colors duration-150`}
            role="listitem"
          >
              <div class="flex items-start justify-between gap-4">
                <!-- Main content -->
                <div class="flex-1 min-w-0">
                  <!-- Title row -->
                  <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 mb-1">
                    <h3 class="text-sm sm:text-[0.98rem] font-bold font-serif text-charcoal group-hover:text-deep-green transition-colors duration-150 leading-snug">
                      {notice.title}
                    </h3>
                    {cfg.label && (
                      <span class={`inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider w-fit ${cfg.badgeBg} ${cfg.badgeText}`}>
                        {cfg.label}
                      </span>
                    )}
                  </div>

                  {/* Description */}
                  {notice.description && (
                    <p class="text-slate text-xs sm:text-sm leading-relaxed line-clamp-2 mb-2">
                      {notice.description}
                    </p>
                  )}

                  {/* Meta row: category + date + CTA */}
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                    {notice.category && (
                      <span class="text-[11px] text-slate-light font-medium uppercase tracking-wider">
                        {notice.category}
                      </span>
                    )}
                    {notice.category && dateFormatted && (
                      <span class="text-[11px] text-ivory-dark">·</span>
                    )}
                    {dateFormatted && (
                      <span class="text-[11px] text-slate-light">{dateFormatted}</span>
                    )}
                    {notice.ctaLabel && notice.ctaHref && (
                      <a
                        href={notice.ctaHref}
                        class="inline-flex items-center gap-1 text-[11px] font-semibold text-deep-green hover:text-deep-green-light transition-colors duration-150 no-underline focus-visible:outline-deep-green ml-auto"
                      >
                        <span class="border-b border-deep-green/40 hover:border-deep-green-light transition-colors duration-150">
                          {notice.ctaLabel}
                        </span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0">
                          <path d="m9 18 6-6-6-6"/>
                        </svg>
                      </a>
                    )}
                  </div>

                  {/* PDF attachment row — university-style: icon, label, date, download */}
                  {notice.pdf && (
                    <div class="notice-pdf-row mt-3 flex items-center gap-3 px-3 py-2.5 bg-ivory/70 rounded-lg border border-ivory-dark hover:border-deep-green/30 hover:bg-deep-green/[0.02] transition-colors duration-150">
                      {/* File type icon */}
                      <div class="flex-shrink-0 w-8 h-8 rounded bg-brand-red/10 flex items-center justify-center">
                        <FileText class="w-4 h-4 text-brand-red" />
                      </div>

                      {/* PDF info */}
                      <div class="flex-1 min-w-0">
                        <p class="text-xs font-semibold text-charcoal leading-tight truncate">
                          {notice.pdf.label}
                        </p>
                        {pdfUploadedFormatted && (
                          <p class="text-[11px] text-slate-light mt-0.5">
                            Uploaded: {pdfUploadedFormatted}
                          </p>
                        )}
                      </div>

                      {/* Download button */}
                      <a
                        href={notice.pdf.file}
                        download
                        class="flex-shrink-0 inline-flex items-center gap-1.5 px-3 py-1.5 bg-deep-green text-white text-[11px] font-semibold rounded-md hover:bg-deep-green-light transition-colors duration-150 no-underline focus-visible:outline-deep-green"
                        aria-label={`Download ${notice.pdf.label}`}
                      >
                        <Download class="w-3.5 h-3.5" />
                        <span>PDF</span>
                      </a>
                    </div>
                  )}
                </div>
              </div>
            </article>
          );
        })}
      </div>

    </div>
  </section>
)}
