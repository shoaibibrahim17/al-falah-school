---
import { LayoutGrid, FlaskConical, Library, Trophy, Palette, Droplets } from "lucide-astro";
import { SCHOOL } from "../data/school";

const iconMap: Record<string, typeof LayoutGrid> = { LayoutGrid, FlaskConical, Library, Trophy, Palette, Droplets };
---

<section id="facilities" class="relative py-16 lg:py-28 bg-white overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-20 left-1/3 w-72 h-72 rounded-full bg-gold/[0.05] blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-gold/15 text-gold-dark rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-gold-dark"></span>
        Campus
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        Our <span class="text-gradient-green">Facilities</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.facilities.subtitle}
      </p>
    </div>

    <div data-reveal-group class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {SCHOOL.facilities.items.map((item) => {
        const Icon = iconMap[item.icon] || LayoutGrid;
        return (
          <article
            data-hover-card
            class="card-facility focus-visible:outline-gold relative group"
            tabindex="0"
          >
            <div class="icon-box">
              <Icon class="w-6 h-6" />
            </div>
            <div class="flex-1">
              <h3 class="font-bold font-serif text-charcoal mb-1 transition-colors duration-300 group-hover:text-deep-green">{item.title}</h3>
              <p class="text-slate text-sm leading-relaxed">{item.description}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
