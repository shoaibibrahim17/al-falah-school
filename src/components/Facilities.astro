---
import { LayoutGrid, FlaskConical, Library, Trophy, Palette, Droplets } from "lucide-astro";
import { SCHOOL } from "../data/school";

const iconMap: Record<string, typeof LayoutGrid> = { LayoutGrid, FlaskConical, Library, Trophy, Palette, Droplets };
---

<section id="facilities" class="py-12 lg:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-8 lg:mb-16">
      <h2 data-animate="fade-up" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4">
        Our <span class="text-deep-green">Facilities</span>
      </h2>
      <p class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.facilities.subtitle}
      </p>
    </div>

    <div data-stagger-group class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {SCHOOL.facilities.items.map((item, i) => {
        const Icon = iconMap[item.icon] || LayoutGrid;
        return (
          <article
            data-hover-card
            class="card-facility focus-visible:outline-gold"
            tabindex="0"
          >
            <div class="icon-box">
              <Icon class="w-6 h-6" />
            </div>
            <div>
              <h3 class="font-bold font-serif text-charcoal mb-1">{item.title}</h3>
              <p class="text-slate text-sm leading-relaxed">{item.description}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
