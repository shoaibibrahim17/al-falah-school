---
import { LayoutGrid, FlaskConical, Library, Trophy, Palette, Droplets } from "lucide-astro";
import { SCHOOL } from "../data/school";

const iconMap: Record<string, typeof LayoutGrid> = { LayoutGrid, FlaskConical, Library, Trophy, Palette, Droplets };
---

{SCHOOL.facilities.enabled && (
<section id="facilities" class="relative py-14 sm:py-16 lg:py-20 bg-white overflow-hidden">
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-8 lg:mb-10">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
        {SCHOOL.facilities.eyebrow}
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        {SCHOOL.facilities.titleLead} <span class="text-gradient-green">{SCHOOL.facilities.titleAccent}</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed max-w-[42rem] mx-auto">
        {SCHOOL.facilities.subtitle}
      </p>
    </div>

    <div data-reveal-group class="grid md:grid-cols-2 gap-3.5 sm:gap-4">
      {SCHOOL.facilities.items.map((item) => {
        const Icon = iconMap[item.icon] || LayoutGrid;
        return (
          <article
            class="flex items-start gap-3 rounded-xl border border-ivory-dark bg-white px-4 py-4 sm:px-5"
          >
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-deep-green/10">
              <Icon class="w-4 h-4 text-deep-green" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold font-serif text-charcoal mb-1.5">{item.title}</h3>
              <p class="text-slate text-sm leading-relaxed">{item.description}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
)}
