---
import { LayoutGrid, FlaskConical, Library, Trophy, Palette, Droplets } from "lucide-astro";
import { SCHOOL } from "../data/school";

const iconMap: Record<string, typeof LayoutGrid> = { LayoutGrid, FlaskConical, Library, Trophy, Palette, Droplets };
---

{SCHOOL.facilities.enabled && (
<section id="facilities" class="relative py-10 sm:py-16 lg:py-20 bg-white overflow-hidden">
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-8 lg:mb-12">
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold font-serif text-charcoal mb-4 tracking-tight">
        {SCHOOL.facilities.titleLead}&nbsp;<span class="text-gradient-green">{SCHOOL.facilities.titleAccent}</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed max-w-[42rem] mx-auto">
        {SCHOOL.facilities.subtitle}
      </p>
    </div>

    <div data-reveal-group class="grid grid-cols-1 sm:grid-cols-2 gap-0 sm:gap-4 divide-y sm:divide-y-0 divide-ivory-dark mt-2 sm:mt-0">
      {SCHOOL.facilities.items.map((item, i) => {
        const Icon = iconMap[item.icon] || LayoutGrid;
        return (
          <article
            class="group flex flex-row items-start gap-4 py-5 sm:card-sweep sm:rounded-2xl sm:border sm:border-ivory-dark sm:bg-white sm:px-5 sm:py-5 transition-all duration-300 sm:hover:shadow-lg sm:hover:shadow-deep-green/5 sm:hover:-translate-y-0.5"
            style={`--order: ${i}`}
          >
            <div class="flex h-10 w-10 sm:h-10 sm:w-10 shrink-0 items-center justify-center rounded-lg bg-deep-green/5 sm:bg-deep-green/10 transition-transform duration-300 group-hover:scale-110">
              <Icon class="w-4 h-4 sm:w-5 sm:h-5 text-deep-green" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-bold font-serif text-charcoal text-[0.95rem] min-[390px]:text-[0.85rem] sm:text-base mb-1.5 min-[390px]:mb-0.5 sm:mb-1.5 leading-snug">{item.title}</h3>
              <p class="text-slate text-[0.8rem] min-[390px]:text-[0.75rem] sm:text-sm leading-relaxed">{item.description}</p>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
)}
