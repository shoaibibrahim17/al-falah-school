---
/* Parent Help Desk — practical, grounded section. Not a SaaS card.
   Two-column on desktop: request types on the left, action panel on the right.
   Stacks cleanly on mobile. Green identity, red only for the label. */
import { ExternalLink } from "lucide-astro";
import { SCHOOL } from "../data/school";

const { parentForm } = SCHOOL;

const hasValidUrl = parentForm.url && !parentForm.url.includes("_example");
---

{parentForm.enabled && (
  <section id="parent-form" class="relative py-14 sm:py-16 lg:py-20 bg-white">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div data-reveal="fade" class="mb-5">
        <span class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-brand-red/10 text-brand-red rounded-full text-sm font-semibold tracking-wide ring-1 ring-brand-red/20">
          {parentForm.label}
        </span>
      </div>

      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-[2.75rem] font-bold font-serif text-charcoal leading-[1.1] tracking-tight mb-4">
        {parentForm.heading}
      </h2>

      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed max-w-2xl mb-8 lg:mb-10">
        {parentForm.description}
      </p>

      <div data-reveal-group class="grid lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.78fr)] gap-5 lg:gap-8 items-start">
        <div class="rounded-2xl border border-ivory-dark bg-white px-4 py-4 sm:px-5">
          <p class="text-xs font-semibold text-slate-light uppercase tracking-wider mb-3">
            {parentForm.requestTypesLabel}
          </p>
          <ul class="space-y-2" role="list">
            {parentForm.requestTypes.map((label) => (
              <li class="flex items-center gap-2 rounded-lg border border-ivory-dark bg-ivory/30 px-3 py-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-deep-green shrink-0" aria-hidden="true"></span>
                <span>{label}</span>
              </li>
            ))}
          </ul>
        </div>

        <div data-reveal="slide-right" class="relative rounded-2xl border border-deep-green/15 bg-ivory/45 p-5 sm:p-6">
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-deep-green-light via-deep-green to-deep-green-dark rounded-t-2xl" aria-hidden="true"></div>
          <h3 class="text-xl sm:text-2xl font-bold font-serif text-charcoal mb-2.5">
            {parentForm.panel.title}
          </h3>
          <p class="text-slate text-sm sm:text-base leading-relaxed mb-5">
            {parentForm.panel.description}
          </p>
          {hasValidUrl ? (
            <a
              href={parentForm.url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary no-underline w-full inline-flex"
              data-cta
            >
              {parentForm.panel.ctaLabel}
              <ExternalLink class="w-4 h-4" />
            </a>
          ) : (
            <button
              type="button"
              disabled
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-charcoal/50 text-white/70 text-sm font-semibold rounded-xl cursor-not-allowed w-full"
            >
              {parentForm.panel.ctaLabel}
              <span class="text-[10px] uppercase tracking-wider">
                {parentForm.panel.urlPlaceholder}
              </span>
            </button>
          )}
          <p class="mt-4 text-xs text-slate-light leading-relaxed max-w-sm">
            {parentForm.panel.note}
          </p>
        </div>
      </div>
    </div>
  </section>
)}
