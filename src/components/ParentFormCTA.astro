---
/* Parent Help Desk — practical, grounded section. Not a SaaS card.
   Two-column on desktop: request types on the left, action panel on the right.
   Stacks cleanly on mobile. Green identity, red only for the label. */
import { ExternalLink } from "lucide-astro";
import { SCHOOL } from "../data/school";

const { parentForm } = SCHOOL;

const hasValidUrl = parentForm.url && !parentForm.url.includes("_example");
---

{parentForm.enabled && (
  <section id="parent-form" class="relative py-16 lg:py-24 bg-white">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section label — red only here -->
      <div data-reveal="fade" class="mb-6">
        <span class="inline-flex items-center gap-2 px-3.5 py-1.5 bg-brand-red/10 text-brand-red rounded-full text-sm font-semibold tracking-wide ring-1 ring-brand-red/20">
          {parentForm.label}
        </span>
      </div>

      <!-- Heading -->
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-[2.75rem] font-bold font-serif text-charcoal leading-[1.1] tracking-tight mb-4">
        {parentForm.heading}
      </h2>

      <!-- Description -->
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed max-w-2xl mb-10 lg:mb-14">
        {parentForm.description}
      </p>

      <!-- Two-column layout -->
      <div data-reveal-group class="grid lg:grid-cols-2 gap-6 lg:gap-10 items-start">

        <!-- Left: request type chips (informational, non-interactive) -->
        <div data-reveal="slide-left">
          <p class="text-xs font-semibold text-slate-light uppercase tracking-wider mb-3">
            Request types accepted
          </p>
          <p class="text-charcoal text-sm sm:text-base leading-relaxed">
            {parentForm.requestTypes.map((label, i) => (
              <>
                <span>{label}</span>
                {i < parentForm.requestTypes.length - 1 && (
                  <span class="text-slate-light mx-1.5" aria-hidden="true">·</span>
                )}
              </>
            ))}
          </p>
        </div>

        <!-- Right: action panel -->
        <div
          data-reveal="slide-right"
          class="relative bg-white rounded-2xl border-2 border-deep-green/20 p-6 sm:p-8 lg:p-10 flex flex-col items-start justify-between"
        >
          <!-- Green top accent bar -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-deep-green-light via-deep-green to-deep-green-dark rounded-t-2xl" aria-hidden="true"></div>

          <div>
            <h3 class="text-xl sm:text-2xl font-bold font-serif text-charcoal mb-3">
              {parentForm.panel.title}
            </h3>
            <p class="text-slate text-sm sm:text-base leading-relaxed mb-6">
              {parentForm.panel.description}
            </p>
          </div>

          <div class="w-full">
            {hasValidUrl ? (
              <a
                href={parentForm.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary no-underline w-full sm:w-auto inline-flex"
                data-cta
              >
                {parentForm.panel.ctaLabel}
                <ExternalLink class="w-4 h-4" />
              </a>
            ) : (
              <button
                type="button"
                disabled
                class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-charcoal/50 text-white/70 text-sm font-semibold rounded-xl cursor-not-allowed w-full sm:w-auto"
              >
                {parentForm.panel.ctaLabel}
                <span class="text-[10px] uppercase tracking-wider">
                  {parentForm.panel.urlPlaceholder}
                </span>
              </button>
            )}

            <p class="mt-5 text-xs text-slate-light leading-relaxed max-w-sm">
              {parentForm.panel.note}
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>
)}
