---
/* Parent Help Desk — practical, grounded section. Not a SaaS card.
   A minimal, professional single-column layout centered on the call to action. */
import { ExternalLink } from "lucide-astro";
import { SCHOOL } from "../data/school";

const { parentForm } = SCHOOL;

const hasValidUrl = parentForm.url && !parentForm.url.includes("_example");
---

{parentForm.enabled && (
  <section id="parent-form" class="relative py-12 sm:py-16 bg-white">
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 data-reveal class="text-3xl sm:text-4xl font-bold font-serif text-charcoal mb-4 tracking-tight leading-tight">
        {parentForm.heading}
      </h2>

      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed max-w-2xl mx-auto mb-6 sm:mb-8">
        {parentForm.description}
      </p>

      <div data-reveal="slide-up" class="flex flex-col items-center justify-center gap-3">
        {hasValidUrl ? (
          <a
            href={parentForm.url}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary no-underline inline-flex items-center gap-2 px-8 py-3"
            data-cta
          >
            {parentForm.panel.ctaLabel}
            <ExternalLink class="w-4 h-4" />
          </a>
        ) : (
          <button
            type="button"
            disabled
            class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-charcoal/50 text-white/70 text-sm font-semibold rounded-xl cursor-not-allowed"
          >
            {parentForm.panel.ctaLabel}
          </button>
        )}
        <p class="text-xs text-slate-light max-w-md mt-2 leading-relaxed">
          {parentForm.panel.note}
        </p>
      </div>
    </div>
  </section>
)}
