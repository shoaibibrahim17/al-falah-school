---
import { BookOpen, Sparkles, Shield, Users, Monitor, Heart } from "lucide-astro";
import { SCHOOL } from "../data/school";

const iconMap: Record<string, typeof BookOpen> = {
  BookOpen, Sparkles, Shield, Users, Monitor, Heart,
};
---

{SCHOOL.whatParentsCanExpect.enabled && (
<section id="what-parents-expect" class="relative py-16 lg:py-24 bg-white overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-10 lg:mb-14">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
        {SCHOOL.whatParentsCanExpect.eyebrow}
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        {SCHOOL.whatParentsCanExpect.titleLead} <span class="text-gradient-green">{SCHOOL.whatParentsCanExpect.titleAccent}</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.whatParentsCanExpect.subtitle}
      </p>
    </div>

    <div data-reveal-group class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {SCHOOL.whatParentsCanExpect.items.map((item) => {
        const Icon = iconMap[item.icon] || BookOpen;
        return (
          <article
            data-hover-card
            class="card-highlight card-sweep relative p-6 lg:p-7 focus-visible:outline-deep-green overflow-hidden"
          >
            <div data-card-inner class="icon-box mb-5 card-highlight-icon transition-colors duration-300" style="--inner-delay: 0ms">
              <Icon class="w-6 h-6 text-deep-green transition-colors duration-300" />
            </div>
            <h3 data-card-inner class="text-lg font-bold font-serif text-charcoal mb-2 transition-colors duration-300" style="--inner-delay: 80ms">
              {item.title}
            </h3>
            <p data-card-inner class="text-slate text-sm leading-relaxed transition-colors duration-300" style="--inner-delay: 160ms">
              {item.description}
            </p>
          </article>
        );
      })}
    </div>
  </div>
</section>
)}
