---
import { ArrowRight, MapPin } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<section id="about" class="relative py-16 lg:py-24 bg-white overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-10 sm:gap-12 lg:gap-16 items-center">
      <!-- Left: Location info as a simple card -->
      <div data-reveal="slide-left">
        <div class="relative">
          <!-- Decorative offset card behind -->
          <div class="absolute inset-0 translate-x-3 translate-y-3 rounded-3xl bg-deep-green/8"></div>

          <!-- Main card -->
          <div class="relative aspect-[4/3] rounded-3xl bg-gradient-to-br from-deep-green to-deep-green-dark overflow-hidden shadow-2xl shadow-deep-green/20">
            <!-- Subtle pattern -->
            <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.06)_1px,transparent_1px)] [background-size:24px_24px]"></div>

            <!-- Top accent glow -->
            <div class="absolute -top-12 -right-12 w-40 h-40 rounded-full bg-white/10 blur-2xl"></div>

            <!-- Center content -->
            <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center">
              <div class="w-20 h-20 rounded-2xl bg-white/10 backdrop-blur-sm flex items-center justify-center mb-5">
                <MapPin class="w-10 h-10 text-white/90" />
              </div>
              <p class="text-white/90 text-base font-medium leading-snug">
                Al-Falah High School
              </p>
              <p class="text-white/70 text-sm mt-1">
                {SCHOOL.location.full}
              </p>
            </div>

            <!-- Bottom label -->
            <div class="absolute bottom-0 inset-x-0 px-6 py-4 bg-gradient-to-t from-charcoal/40 to-transparent">
              <p class="text-white/80 text-sm font-medium tracking-wide">English Medium · State Board</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Text content -->
      <div data-reveal="slide-right">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
          Our Story
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal leading-tight mb-5 sm:mb-6 tracking-tight">
          About <span class="text-gradient-green">Al-Falah</span>
        </h2>
        <div class="space-y-4 sm:space-y-5">
          {SCHOOL.about.paragraphs.map((p) => (
            <p class="text-slate leading-relaxed text-base sm:text-lg">{p}</p>
          ))}
        </div>
        <div class="mt-8">
          <a
            href={SCHOOL.about.linkHref}
            class="group link-arrow text-deep-green font-semibold hover:text-deep-green-light transition-colors duration-200 no-underline focus-visible:outline-deep-green cursor-pointer"
          >
            <span>{SCHOOL.about.linkText}</span>
            <ArrowRight class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>