---
import { School, ArrowRight, BookOpen, GraduationCap, Sparkles, Leaf } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<section id="about" class="relative py-16 lg:py-28 bg-ivory overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(#0D5E3E_0.6px,transparent_0.6px)] [background-size:32px_32px] opacity-[0.03]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-10 sm:gap-12 lg:gap-20 items-center">
      <!-- Stylized illustration panel -->
      <div data-reveal="slide-left" aria-hidden="true">
        <div class="relative">
          <!-- Decorative offset card behind -->
          <div class="absolute inset-0 translate-x-3 translate-y-3 rounded-3xl bg-gradient-to-br from-gold/15 to-deep-green/10"></div>
          <div class="absolute inset-0 -translate-x-2 -translate-y-2 rounded-3xl bg-gradient-to-tl from-deep-green/8 to-gold/8"></div>

          <!-- Main illustration card -->
          <div class="relative aspect-[4/3] rounded-3xl bg-gradient-to-br from-deep-green to-deep-green-dark overflow-hidden shadow-2xl shadow-deep-green/20">
            <!-- Subtle pattern -->
            <div class="absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.08)_1px,transparent_1px)] [background-size:20px_20px]"></div>

            <!-- Floating ambient circles -->
            <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-gold/20 blur-2xl breathe-slow"></div>
            <div class="absolute -bottom-12 -left-12 w-48 h-48 rounded-full bg-white/10 blur-3xl breathe-slow delay"></div>

            <!-- Composed icon graphic -->
            <div class="absolute inset-0 flex items-center justify-center p-8">
              <div class="relative">
                <!-- Center primary icon -->
                <div class="w-28 h-28 sm:w-32 sm:h-32 rounded-3xl bg-white/95 backdrop-blur-sm flex items-center justify-center shadow-xl shadow-charcoal/20">
                  <School class="w-14 h-14 sm:w-16 sm:h-16 text-deep-green" />
                </div>

                <!-- Orbiting icon tiles -->
                <div class="absolute -top-5 -left-8 w-12 h-12 rounded-2xl bg-gold flex items-center justify-center shadow-lg shadow-gold/40 float-soft">
                  <BookOpen class="w-6 h-6 text-white" />
                </div>
                <div class="absolute -top-6 -right-9 w-12 h-12 rounded-2xl bg-white flex items-center justify-center shadow-lg shadow-charcoal/20 float-soft" style="animation-delay: -1.2s">
                  <GraduationCap class="w-6 h-6 text-deep-green" />
                </div>
                <div class="absolute -bottom-5 -left-6 w-11 h-11 rounded-2xl bg-white flex items-center justify-center shadow-lg shadow-charcoal/20 float-soft" style="animation-delay: -0.6s">
                  <Leaf class="w-5 h-5 text-deep-green-light" />
                </div>
                <div class="absolute -bottom-6 -right-8 w-12 h-12 rounded-2xl bg-gold-light flex items-center justify-center shadow-lg shadow-gold/40 float-soft" style="animation-delay: -1.8s">
                  <Sparkles class="w-6 h-6 text-charcoal" />
                </div>
              </div>
            </div>

            <!-- Caption ribbon -->
            <div class="absolute bottom-0 inset-x-0 px-6 py-4 bg-gradient-to-t from-charcoal/40 to-transparent">
              <p class="text-white/95 text-sm font-medium tracking-wide">{SCHOOL.location.full}</p>
            </div>
          </div>
        </div>
      </div>

      <div data-reveal="slide-right">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
          Our Story
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal leading-tight mb-5 sm:mb-6 tracking-tight">
          <span class="text-gradient-green">About</span> {SCHOOL.about.heading.split(" ").slice(1).join(" ")}
        </h2>
        <div class="space-y-4 sm:space-y-5">
          {SCHOOL.about.paragraphs.map((p) => (
            <p class="text-slate leading-relaxed text-base sm:text-lg">{p}</p>
          ))}
        </div>
        <div class="mt-8">
          <a
            href={SCHOOL.about.linkHref}
            class="group link-arrow text-deep-green font-semibold hover:text-deep-green-light transition-colors duration-200 no-underline focus-visible:outline-gold cursor-pointer"
          >
            <span>{SCHOOL.about.linkText}</span>
            <ArrowRight class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
