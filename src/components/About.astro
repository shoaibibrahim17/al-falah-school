---
import { ArrowRight, Image as ImageIcon } from "lucide-astro";
import { SCHOOL } from "../data/school";

const { about } = SCHOOL;
const hasImage = about.image?.isActive && Boolean(about.image?.src);
---

{about.enabled && (
<section id="about" class="relative py-14 sm:py-16 lg:py-20 bg-white overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class:list={[
      "grid gap-4 sm:gap-8 lg:gap-10 items-start max-w-6xl mx-auto",
      hasImage ? "grid-cols-[minmax(0,1.25fr)_minmax(0,0.75fr)]" : "grid-cols-[minmax(0,1fr)]",
    ]}>
      <div data-reveal="fade" class="relative max-w-[42rem] min-w-0">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-3">
            <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
            {about.eyebrow}
          </div>
          <h2 class="text-[1.5rem] sm:text-4xl lg:text-[2.85rem] font-bold text-charcoal leading-[1.12] sm:leading-tight mb-3 sm:mb-5 tracking-tight">
            {about.titleLead} <span class="text-gradient-green">{about.titleAccent}</span>
          </h2>
          <div class="space-y-2.5 sm:space-y-[1.125rem]">
            {about.paragraphs.map((p) => (
              <p class="text-slate leading-relaxed text-[0.86rem] sm:text-[1.02rem]">{p}</p>
            ))}
          </div>
          <div class="mt-5 sm:mt-8">
            <a
              href={about.linkHref}
              class="group link-arrow text-deep-green font-semibold hover:text-deep-green-light transition-colors duration-200 no-underline focus-visible:outline-deep-green cursor-pointer text-sm"
            >
              <span>{about.linkText}</span>
              <ArrowRight class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
            </a>
          </div>
      </div>

      <aside data-reveal="slide-right" class="w-full min-w-0 justify-self-end">
        {hasImage ? (
          <figure class="relative aspect-square sm:aspect-[4/3] rounded-2xl overflow-hidden border border-deep-green/15 bg-ivory shadow-sm">
            <img
              src={about.image!.src!}
              alt={about.image!.alt || "School campus photo"}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
            {about.image!.caption && (
              <figcaption class="absolute bottom-0 inset-x-0 px-4 py-2.5 bg-gradient-to-t from-charcoal/60 to-transparent">
                <p class="text-white/90 text-xs sm:text-sm font-medium">{about.image!.caption}</p>
              </figcaption>
            )}
          </figure>
        ) : (
          <div class="rounded-2xl border border-ivory-dark bg-ivory/55 px-4 py-4 sm:px-5">
            <div class="flex items-start gap-3 text-left">
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-deep-green/10">
                <ImageIcon class="h-5 w-5 text-deep-green" />
              </div>
              <div>
                <p class="text-sm font-semibold text-charcoal">{about.placeholderTitle}</p>
                <p class="mt-1 text-xs leading-relaxed text-slate-light">
                  {about.placeholderDescription}
                </p>
              </div>
            </div>
          </div>
        )}
      </aside>
    </div>
  </div>
</section>
)}
