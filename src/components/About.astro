---
import { ArrowRight, Image as ImageIcon } from "lucide-astro";
import { SCHOOL } from "../data/school";
import AcademicDoodles from "./AcademicDoodles.astro";

const { about } = SCHOOL;
const hasImage = about.image?.isActive && Boolean(about.image?.src);
---

{about.enabled && (
<section id="about" class="relative py-16 lg:py-24 bg-white overflow-hidden">
  <!-- Decorative background doodles — 1 subtle school/book doodle in corner -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-12 right-[6%] opacity-60 hidden sm:block">
      <AcademicDoodles variant="school" size="sm" color="slate" rotation={-6} opacity={0.45} />
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class:list={["grid gap-10 sm:gap-12 lg:gap-16 items-center", hasImage ? "md:grid-cols-2" : "max-w-3xl mx-auto"]}>
      <!-- Left: CMS-ready image area -->
      {hasImage && (
        <div data-reveal="slide-left">
          <div class="relative">
            <figure class="relative aspect-[4/3] rounded-3xl overflow-hidden border border-deep-green/20 shadow-lg shadow-deep-green/10 bg-ivory">
              <img
                src={about.image!.src!}
                alt={about.image!.alt || "School campus photo"}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              {about.image!.caption && (
                <figcaption class="absolute bottom-0 inset-x-0 px-4 py-2.5 bg-gradient-to-t from-charcoal/60 to-transparent">
                  <p class="text-white/90 text-xs sm:text-sm font-medium">{about.image!.caption}</p>
                </figcaption>
              )}
            </figure>
          </div>
        </div>
      )}

      <!-- Right: Text content -->
      <div data-reveal={hasImage ? "slide-right" : "fade"}>
        <div class="relative">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
            {about.eyebrow}
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal leading-tight mb-5 sm:mb-6 tracking-tight">
            {about.titleLead} <span class="text-gradient-green">{about.titleAccent}</span>
          </h2>
          <div class="space-y-4 sm:space-y-5">
            {about.paragraphs.map((p) => (
              <p class="text-slate leading-relaxed text-base sm:text-lg">{p}</p>
            ))}
          </div>
          {!hasImage && (
            <div
              class="mt-6 inline-flex max-w-md items-start gap-3 rounded-2xl border border-dashed border-deep-green/25 bg-ivory/45 px-4 py-3 text-left"
              role="note"
              aria-label={about.imagePlaceholder}
            >
              <div class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-deep-green/10">
                <ImageIcon class="h-5 w-5 text-deep-green" />
              </div>
              <div>
                <p class="text-sm font-semibold text-charcoal">{about.placeholderTitle}</p>
                <p class="mt-1 text-xs leading-relaxed text-slate-light">
                  {about.placeholderDescription}
                </p>
              </div>
            </div>
          )}
          <div class="mt-8">
            <a
              href={about.linkHref}
              class="group link-arrow text-deep-green font-semibold hover:text-deep-green-light transition-colors duration-200 no-underline focus-visible:outline-deep-green cursor-pointer"
            >
              <span>{about.linkText}</span>
              <ArrowRight class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1.5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
)}
