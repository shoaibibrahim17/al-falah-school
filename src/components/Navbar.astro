---
import { Menu, Phone } from "lucide-astro";
import { SCHOOL } from "../data/school";
---

<!--
  Sticky navigation that sits below the BrandHeader strip. Renders in
  normal document flow at scroll = 0 and sticks to top:0 once the user
  scrolls past the brand header. No logo here — the BrandHeader is the
  identity element; this strip is for navigation only.
-->
<div data-navbar class="brand-nav sticky top-0 z-50">
  <nav class="bg-white/95 backdrop-blur-md border-b border-deep-green/20" aria-label="Main navigation">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="nav-inner flex items-center justify-between h-14 lg:h-16">

        <!-- Desktop nav links (left) -->
        <div class="hidden lg:flex items-center gap-7">
          {SCHOOL.nav.links.map((link) => (
            <a
              href={link.href}
              class="nav-link text-sm font-medium text-charcoal hover:text-deep-green transition-colors duration-200 no-underline focus-visible:outline-deep-green"
            >
              {link.label}
            </a>
          ))}
          {SCHOOL.faculty.enabled && (
            <a
              href="#faculty"
              class="nav-link text-sm font-medium text-charcoal hover:text-deep-green transition-colors duration-200 no-underline focus-visible:outline-deep-green"
            >
              Faculty
            </a>
          )}
        </div>

        <!-- Mobile: show "Menu" label + icon (left aligned so the nav row isn't empty on mobile) -->
        <button
          id="menu-toggle"
          class="lg:hidden inline-flex items-center gap-2 px-3 py-2 text-deep-green hover:text-deep-green-light transition-colors duration-200 cursor-pointer focus-visible:outline-deep-green min-h-[44px] -ml-2"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Menu class="w-5 h-5" id="menu-icon" />
          <span class="text-sm font-semibold">Menu</span>
        </button>

        <!-- Right side: CTA -->
        <a
          href="#contact"
          class="btn-primary !px-4 sm:!px-5 !py-2 sm:!py-2.5 !text-sm !rounded-lg no-underline"
        >
          <Phone class="w-4 h-4" />
          <span class="hidden sm:inline">{SCHOOL.nav.cta}</span>
          <span class="sm:hidden">Enquire</span>
        </a>
      </div>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-deep-green/15" role="navigation" aria-label="Mobile navigation">
      <div class="px-4 py-4 space-y-1">
        {SCHOOL.nav.links.map((link) => (
          <a
            href={link.href}
            class="block text-base font-medium text-charcoal hover:text-deep-green hover:bg-deep-green/5 rounded-lg transition-colors duration-200 no-underline focus-visible:outline-deep-green px-3 py-3"
          >
            {link.label}
          </a>
        ))}
        {SCHOOL.faculty.enabled && (
          <a
            href="#faculty"
            class="block text-base font-medium text-charcoal hover:text-deep-green hover:bg-deep-green/5 rounded-lg transition-colors duration-200 no-underline focus-visible:outline-deep-green px-3 py-3"
          >
            Faculty
          </a>
        )}
      </div>
    </div>
  </nav>
</div>

<script>
  /* Mobile menu toggle */
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const icon = document.getElementById("menu-icon");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = !menu.classList.contains("hidden");
      menu.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", String(!isOpen));
      if (icon) {
        if (isOpen) {
          icon.outerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu w-5 h-5" id="menu-icon"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/></svg>';
        } else {
          icon.outerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x w-5 h-5" id="menu-icon"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
        }
      }
    });
  }
</script>
