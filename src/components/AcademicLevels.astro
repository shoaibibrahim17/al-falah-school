---
import { Baby, BookOpen, Library, GraduationCap } from "lucide-astro";
import { SCHOOL } from "../data/school";

const iconMap: Record<string, typeof Baby> = { Baby, BookOpen, Library, GraduationCap };
---

{SCHOOL.academicLevels.enabled && (
<section id="academics" class="relative py-14 sm:py-16 lg:py-20 bg-white overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-8 sm:mb-10 lg:mb-12">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
        {SCHOOL.academicLevels.eyebrow}
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        {SCHOOL.academicLevels.titleLead} <span class="text-gradient-green">{SCHOOL.academicLevels.titleAccent}</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.academicLevels.subtitle}
      </p>
    </div>

    <div data-reveal-group class="relative max-w-4xl mx-auto">
      <div class="absolute left-[1.15rem] sm:left-[1.35rem] top-2 bottom-2 w-px bg-deep-green/10" aria-hidden="true"></div>
        {SCHOOL.academicLevels.levels.map((level, i) => {
          const Icon = iconMap[level.icon] || BookOpen;
          const stepNo = String(i + 1).padStart(2, "0");
          return (
            <article
              class="relative pl-10 sm:pl-12 pb-4 sm:pb-5"
            >
              <div class="absolute left-0 top-0 flex h-8 w-8 items-center justify-center rounded-full bg-white ring-1 ring-deep-green/15">
                <Icon class="w-4 h-4 text-deep-green" />
              </div>
              <div class="rounded-xl border border-ivory-dark bg-white px-4 py-4 sm:px-5">
                <div class="flex items-start gap-3">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2 mb-2">
                      <span class="inline-flex h-6 min-w-6 items-center justify-center rounded-full bg-ivory text-[11px] font-semibold text-deep-green px-1.5">
                        {stepNo}
                      </span>
                      <h3 class="text-lg font-bold font-serif text-charcoal leading-snug">{level.level}</h3>
                    </div>
                    {(level.ages || level.grades) && (
                      <span class="inline-flex items-center px-2.5 py-0.5 bg-deep-green/10 text-deep-green text-xs font-semibold rounded-full mb-2.5 tracking-wide">
                        {level.ages ?? level.grades}
                      </span>
                    )}
                    <p class="text-slate text-sm leading-relaxed">{level.description}</p>
                  </div>
                </div>
              </div>
            </article>
          );
        })}
    </div>
  </div>
</section>
)}
