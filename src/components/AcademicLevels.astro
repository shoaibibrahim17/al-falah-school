---
import { Baby, BookOpen, Library, GraduationCap } from "lucide-astro";
import { SCHOOL } from "../data/school";

const iconMap: Record<string, typeof Baby> = { Baby, BookOpen, Library, GraduationCap };
---

<section id="academics" class="relative py-16 lg:py-28 bg-white overflow-hidden">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/3 right-0 w-72 h-72 rounded-full bg-deep-green/[0.06] blur-3xl"></div>
    <div class="absolute bottom-1/3 left-0 w-72 h-72 rounded-full bg-deep-green/[0.05] blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-20">
      <div data-reveal="fade" class="inline-flex items-center gap-2 px-3 py-1 bg-deep-green/10 text-deep-green rounded-full text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-deep-green"></span>
        Curriculum
      </div>
      <h2 data-reveal class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal mb-4 tracking-tight">
        Academic <span class="text-gradient-green">Levels</span>
      </h2>
      <p data-reveal class="text-slate text-base sm:text-lg leading-relaxed">
        {SCHOOL.academicLevels.subtitle}
      </p>
    </div>

    <div class="relative">
      <!-- Connecting line (desktop only) -->
      <div class="hidden lg:block absolute left-0 right-0 top-[5.5rem] h-px pointer-events-none" aria-hidden="true">
        <div class="h-full bg-[linear-gradient(to_right,transparent,var(--color-deep-green)_15%,var(--color-deep-green)_85%,transparent)] opacity-20"></div>
      </div>

      <div data-reveal-group class="relative grid sm:grid-cols-2 lg:grid-cols-4 gap-5 sm:gap-6">
        {SCHOOL.academicLevels.levels.map((level, i) => {
          const Icon = iconMap[level.icon] || BookOpen;
          const stepNo = String(i + 1).padStart(2, "0");
          return (
            <article
              data-hover-card
              class="relative group bg-white rounded-2xl p-6 lg:p-7 border border-ivory-dark focus-visible:outline-deep-green cursor-pointer overflow-hidden card-sweep"
              tabindex="0"
            >
              <!-- Ghost number in corner -->
              <span data-card-inner class="absolute top-3 right-4 text-[2.5rem] font-bold font-serif text-deep-green/[0.08] leading-none select-none transition-colors duration-500 group-hover:text-deep-green/20 group-hover:scale-110" style="--inner-delay: 0ms">
                {stepNo}
              </span>

              <!-- Icon (in front of node dot) -->
              <div data-card-inner class="relative inline-flex items-center justify-center mb-5" style="--inner-delay: 80ms">
                <div class="absolute inset-0 -m-1 rounded-2xl bg-deep-green/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-md"></div>
                <div class="relative w-14 h-14 rounded-2xl bg-gradient-to-br from-deep-green to-deep-green-light flex items-center justify-center shadow-lg shadow-deep-green/25 transition-transform duration-500 ease-out group-hover:rotate-[-6deg] group-hover:scale-110">
                  <Icon class="w-7 h-7 text-white" />
                </div>
              </div>

              <h3 data-card-inner class="text-xl font-bold font-serif text-charcoal mb-1.5 transition-colors duration-300 group-hover:text-deep-green" style="--inner-delay: 160ms">{level.level}</h3>
              {level.ages && (
                <span data-card-inner class="inline-flex items-center px-2.5 py-0.5 bg-deep-green/10 text-deep-green text-xs font-semibold rounded-full mb-3 tracking-wide" style="--inner-delay: 220ms">
                  {level.ages}
                </span>
              )}
              {level.grades && (
                <span data-card-inner class="inline-flex items-center px-2.5 py-0.5 bg-deep-green/10 text-deep-green text-xs font-semibold rounded-full mb-3 tracking-wide" style="--inner-delay: 220ms">
                  {level.grades}
                </span>
              )}
              <p data-card-inner class="text-slate text-sm leading-relaxed mt-1" style="--inner-delay: 280ms">{level.description}</p>

              <!-- Bottom accent bar -->
              <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-deep-green to-transparent scale-x-0 origin-center group-hover:scale-x-100 transition-transform duration-500 ease-out"></div>
            </article>
          );
        })}
      </div>
    </div>
  </div>
</section>
